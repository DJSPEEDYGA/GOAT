{
  "name": "kubiks-nextjs-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Next.js starter template for Kubiks - Desktop App",
  "author": "Kubiks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DJSPEEDYGA/kubiks-next-js-starter"
  },
  "main": "electron.js",
  "keywords": [
    "nextjs",
    "opentelemetry",
    "observability",
    "kubiks",
    "telemetry",
    "monitoring",
    "tracing",
    "electron",
    "desktop"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@vercel/otel": "^2.0.1",
    "next": "15.5.9",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^34.1.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "15.5.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.kubiks.nextjs-starter",
    "productName": "Kubiks Starter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron.js",
      "preload.js",
      ".next/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "Kubiks-Starter-Portable.exe"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "tar.gz", "arch": ["x64"] }
      ],
      "category": "Development"
    }
  }
}