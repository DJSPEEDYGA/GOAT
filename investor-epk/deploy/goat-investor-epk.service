[Unit]
Description=GOAT Royalty — Gated Investor Living EPK
After=network.target

[Service]
Type=simple
# Adjust user and path to match the target server layout.
User=www-data
WorkingDirectory=/opt/goat-investor-epk
EnvironmentFile=/opt/goat-investor-epk/.env
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=3
# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/goat-investor-epk/data

[Install]
WantedBy=multi-user.target
