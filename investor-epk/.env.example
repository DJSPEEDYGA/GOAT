# Copy to .env and fill in. NEVER commit the real .env.

# Port the gate listens on (nginx proxies to this).
PORT=4600

# Secret used to sign session JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-hex-string

# Owner/admin token for the approval console (/admin). Generate the same way.
ADMIN_TOKEN=change-me-to-a-long-random-hex-string

# Session lifetime once a partner is fully authenticated (minutes).
SESSION_TTL_MINUTES=120

# Set true in production (behind HTTPS) so cookies are Secure-only.
COOKIE_SECURE=false

# Number of reverse proxies in front of the app (nginx = 1) for correct client IP.
TRUST_PROXY_HOPS=1

# When true, a brand-new IP for a partner is held PENDING until the owner
# approves it in /admin. This is the "trace + approve every login" gate.
REQUIRE_IP_APPROVAL=true
