{
  "name": "goat-royalty-app",
  "version": "1.0.0",
  "description": "GOAT - All-in-One AI-Powered Royalty, Blockchain, DSP Distribution, Video Editing & Crypto Mining App",
  "author": "DJ Speedy",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "python -m uvicorn src.core.app:app --reload --port 8000",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "pyinstaller --onefile --windowed --name GOAT src/core/main.py",
    "build:exe": "npm run build && node scripts/create-exe.js",
    "build:dmg": "npm run build && node scripts/create-dmg.js",
    "build:portable": "npm run build && node scripts/create-portable.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "crewai": "^0.86.0",
    "ethers": "^6.13.0",
    "langchain": "^0.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}