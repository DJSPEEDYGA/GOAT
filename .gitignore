# Dependencies (rebuildable — never commit)
**/node_modules/
**/.pnp
**/.pnp.js

# Build output / caches
**/.next/
**/out/
**/dist/
**/build/
**/.turbo/
**/.cache/

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Env / secrets
**/.env.local
**/.env*.local

# OS
.DS_Store
**/.DS_Store
Thumbs.db

# Live-server backup safety: never commit real secrets/data pulled from servers
live-server/**/local_keys.json
live-server/**/*.db
live-server/**/chat_data/
__pycache__/

# Consolidation cleanup
**/desktop-builds/
**/*.zip
**/*.tar.gz
**/*.deb
**/.env
