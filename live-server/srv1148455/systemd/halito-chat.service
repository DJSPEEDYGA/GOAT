[Unit]
Description=Halito Chat web relay
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/srv/halito-chat
Environment=NODE_ENV=production
Environment=HOST=127.0.0.1
Environment=PORT=4177
ExecStart=/usr/bin/env node /srv/halito-chat/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
