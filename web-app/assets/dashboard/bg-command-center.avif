  document.getElementById('profile-email').value = me.data.user.email;
  document.getElementById('profile-modal-overlay').classList.add('open');
});
document.getElementById('close-profile-modal').addEventListener('click', () => document.getElementById('profile-modal-overlay').classList.remove('open'));
document.getElementById('profile-modal-overlay').addEventListener('click', e => { if (e.target.id === 'profile-modal-overlay') document.getElementById('profile-modal-overlay').classList.remove('open'); });

document.getElementById('profile-form').addEventListener('submit', async e => {
  e.preventDefault();
  const email = document.getElementById('profile-email').value.trim();
  const emailPass = document.getElementById('profile-password').value;
  const current = document.getElementById('current-password').value;
  const newPass = document.getElementById('new-password').value;
  const confirm = document.getElementById('confirm-password').value;

  const me = await api('/api/me');
  const currentEmail = me.data.user.email;

  if (email !== currentEmail) {
    const { data } = await api('/api/change_email', { method: 'POST', body: { email, password: emailPass } });
    if (!data.ok) { alert(data.error); return; }
  }

  if (newPass) {
    const { data } = await api('/api/change_password', { method: 'POST', body: { current, new: newPass, confirm } });
    if (!data.ok) { alert(data.error); return; }
  }

  alert('Profile updated. Please log in again if you changed your email.');
  document.getElementById('profile-modal-overlay').classList.remove('open');
  if (email !== currentEmail || newPass) await api('/api/logout', { method: 'POST' }), location.reload();
});

// Table edit/delete delegation
const tableMap = {
  sales: 'sales-table', orders: 'orders-table', employees: 'emp-table', finance: 'fin-table',
  inventory: 'inv-table', entities: 'ent-table', accounting: 'acct-table'
};
Object.entries(tableMap).forEach(([page, id]) => {
  const table = document.getElementById(id);
  if (!table) return;
  table.addEventListener('click', e => {
    const btn = e.target.closest('button'); if (!btn) return;
    const id = btn.dataset.id; const type = btn.dataset.type;
    if (btn.dataset.action === 'edit') openModal(type, id);
    if (btn.dataset.action === 'delete') deleteItem(type, id);
  });
});

// Journal entries table delegation
document.getElementById('je-table').addEventListener('click', e => {
  const btn = e.target.closest('button'); if (!btn) return;
  if (btn.dataset.action === 'edit') openModal('journal_entry', btn.dataset.id);
  if (btn.dataset.action === 'delete') deleteItem('journal_entry', btn.dataset.id);
});

// Projects list delegation (cards + add-task + task edit/delete)
document.getElementById('projects-list').addEventListener('click', e => {
  const btn = e.target.closest('button'); if (!btn) return;
  if (btn.dataset.action === 'add-task') { editingType = null; openModal('task'); /* project_id select will be set by user */ return; }
  if (btn.dataset.action === 'edit') openModal(btn.dataset.type, btn.dataset.id);
  if (btn.dataset.action === 'delete') deleteItem(btn.dataset.type, btn.dataset.id);
});

