    <symbol id="icon-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></symbol>
    <symbol id="icon-refresh-cw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></symbol>
    <symbol id="icon-play" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></symbol>
    <symbol id="icon-square" viewBox="0 0 24 24" fill="currentColor" stroke="none"><rect x="4" y="4" width="16" height="16" rx="2"/></symbol>
    <symbol id="icon-file-text" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></symbol>
    <symbol id="icon-shield" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
    <symbol id="icon-credit-card" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></symbol>
    <symbol id="icon-log-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></symbol>
    <symbol id="icon-zap" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></symbol>
    <symbol id="icon-target" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></symbol>
    <symbol id="icon-user" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></symbol>
    <symbol id="icon-download" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></symbol>
    <symbol id="icon-disc" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></symbol>
    <symbol id="icon-shopping-bag" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></symbol>
    <symbol id="icon-layers" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></symbol>
    <symbol id="icon-grid" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></symbol>
    <symbol id="icon-dice" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="8" cy="8" r="1.5" fill="currentColor" stroke="none"/><circle cx="16" cy="8" r="1.5" fill="currentColor" stroke="none"/><circle cx="8" cy="16" r="1.5" fill="currentColor" stroke="none"/><circle cx="16" cy="16" r="1.5" fill="currentColor" stroke="none"/></symbol>
  </defs>
</svg>

<div class="login-view" id="login-view">
  <div class="login-card">
    <div class="brand" style="margin-bottom:18px"><div class="logo">G</div>GOAT FORCE COMMAND</div>
    <h1>Secure Access</h1>
    <p>Tactical command interface for GOAT Force missions.</p>
    <form id="login-form">
      <div class="form-group">
        <label for="login-email">Email</label>
        <input type="email" id="login-email" value="harvey@bsmmusic.com" required />
      </div>
      <div class="form-group">
        <label for="login-pass">Password</label>
        <input type="password" id="login-pass" value="Djspeedy1976@" required />
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%" id="login-btn">Enter command center</button>
      <div class="error-msg" id="login-error">Invalid email or password.</div>
    </form>
  </div>
</div>

<div class="hud-corner tl"></div>
<div class="hud-corner tr"></div>
<div class="hud-corner bl"></div>
<div class="hud-corner br"></div>

<div class="app-view" id="app-view">
  <aside class="sidebar" id="sidebar">
    <div class="brand"><div class="logo"><svg class="icon icon-lg"><use href="#icon-zap"></use></svg></div>GOAT FORCE COMMAND</div>
    <ul class="nav" id="nav">
      <li><a href="/mission-control" class="nav-link" style="color:var(--green);border-left:3px solid var(--green);background:rgba(163,198,68,0.08)"><svg class="icon"><use href="#icon-target"></use></svg> Mission Control</a></li>
      <li><button data-page="home" class="active"><svg class="icon"><use href="#icon-grid"></use></svg> Home Base</button></li>
      <li><button data-page="dashboard"><svg class="icon"><use href="#icon-layout"></use></svg> Mission Dashboard</button></li>
      <li><button data-page="sales"><svg class="icon"><use href="#icon-briefcase"></use></svg> Sales Ops</button></li>
      <li><button data-page="orders"><svg class="icon"><use href="#icon-truck"></use></svg> Fulfillment</button></li>
      <li><button data-page="employees"><svg class="icon"><use href="#icon-users"></use></svg> Personnel</button></li>
      <li><button data-page="finance"><svg class="icon"><use href="#icon-credit-card"></use></svg> Treasury</button></li>
      <li><button data-page="inventory"><svg class="icon"><use href="#icon-package"></use></svg> Arsenal</button></li>
      <li><button data-page="entities"><svg class="icon"><use href="#icon-globe"></use></svg> Units</button></li>
      <li><button data-page="royalties"><svg class="icon"><use href="#icon-disc"></use></svg> Royalties</button></li>
      <li><button data-page="accounting"><svg class="icon"><use href="#icon-book-open"></use></svg> Accounting</button></li>
      <li><button data-page="projects"><svg class="icon"><use href="#icon-folder"></use></svg> Operations</button></li>
      <li><button data-page="analytics"><svg class="icon"><use href="#icon-bar-chart"></use></svg> Intel</button></li>
      <li><button data-page="banking"><svg class="icon"><use href="#icon-credit-card"></use></svg> Banking</button></li>
      <li><button data-page="trading"><svg class="icon"><use href="#icon-trending-up"></use></svg> Crypto Ops</button></li>
      <li><button data-page="vault"><svg class="icon"><use href="#icon-file-text"></use></svg> Vault</button></li>
      <li><button data-page="audit"><svg class="icon"><use href="#icon-shield"></use></svg> Audit</button></li>
      <li><button data-page="ai"><svg class="icon"><use href="#icon-cpu"></use></svg> AI Command</button></li>
      <li><button data-page="casino"><svg class="icon"><use href="#icon-dice"></use></svg> Casino Ops</button></li>
      <li><button data-page="downloads"><svg class="icon"><use href="#icon-download"></use></svg> Logistics</button></li>
      <li><button data-page="settings"><svg class="icon"><use href="#icon-shield"></use></svg> MONOPOLY Lock</button></li>
    </ul>
    <div class="sidebar-footer">
      <div id="user-info">Admin</div>
      <button class="btn btn-ghost btn-sm" style="width:100%;margin-top:10px" id="profile-btn"><svg class="icon"><use href="#icon-user"></use></svg> Profile</button>
      <button class="btn btn-ghost btn-sm" style="width:100%;margin-top:8px" id="logout-btn">Log out</button>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <button class="menu-toggle" id="menu-toggle"><svg class="icon"><use href="#icon-menu"></use></svg></button>
      <h2 id="page-title">Dashboard</h2>
      <div class="topbar-actions">
        <select class="entity-select" id="entity-select" title="Switch entity"></select>
        <div class="search"><svg class="icon search-icon"><use href="#icon-search"></use></svg><input type="text" id="global-search" placeholder="Search records…" /></div>
        <button class="btn btn-ghost btn-sm" id="notifications"><svg class="icon"><use href="#icon-bell"></use></svg></button>
        <div class="avatar"><svg class="icon"><use href="#icon-user"></use></svg></div>
      </div>
    </header>

    <div class="command-bar" id="command-bar">
      <span class="status-item"><span class="status-light" id="sys-status-light"></span> System: <span id="sys-status-text">CHECKING</span></span>
      <span class="status-item"><span class="status-light amber" id="cash-light"></span> Cash: <span id="command-cash">--</span></span>
      <span class="status-item"><span class="status-light" id="deals-light"></span> Open Deals: <span id="command-deals">--</span></span>
      <span class="status-item"><span class="status-light red" id="alert-light"></span> Alerts: <span id="command-alerts">--</span></span>
      <span class="mission-clock" id="mission-clock">00:00:00 UTC</span>
    </div>

    <div class="content" id="content">
      <section class="page active" id="page-home">
        <div class="home-header">
          <div>
            <p class="home-greeting">OPERATOR ONLINE</p>
            <h1 id="home-title">GOAT FORCE COMMAND</h1>
            <p class="home-subtitle" id="home-subtitle">Commander · GOAT Force Records — USA</p>
          </div>
          <div class="home-actions">
            <button class="btn btn-ghost" id="home-dashboard-btn"><svg class="icon"><use href="#icon-bar-chart"></use></svg> View Dashboard</button>
            <button class="btn btn-primary" id="home-ai-btn"><svg class="icon"><use href="#icon-cpu"></use></svg> Ask AI</button>
          </div>
        </div>
        <div class="ai-prompt card" style="border-top-color:var(--gold)">
          <div class="card-header"><h3>MONOPOLY MONEY — AI Agent</h3><p>Issue a natural-language directive or ask the AI to run commands, search, read files, and manage missions</p></div>
          <form class="ai-input" id="home-ai-form"><input type="text" id="home-ai-input" placeholder="e.g. 'What is our net income?' or 'Run git status'" autocomplete="off" /><button type="submit" class="btn btn-primary">Ask</button></form>
          <div class="ai-chips">
            <button class="ai-chip" data-q="cash balance">Cash balance</button>
            <button class="ai-chip" data-q="open deals">Open deals</button>
            <button class="ai-chip" data-q="overdue invoices">Overdue invoices</button>
            <button class="ai-chip" data-q="low stock">Low stock</button>
            <button class="ai-chip" data-q="market intel">Market intel</button>
            <button class="ai-chip" data-q="agent roster">Agent roster</button>
          </div>
          <div id="home-ai-answer" style="margin-top:14px;display:none"><div class="ai-msg bot"></div></div>
        </div>
        <h3 class="section-title">Apps</h3>
        <div class="app-tiles" id="app-tiles"></div>
        <div class="card" style="border-top-color:var(--gold);margin-bottom:18px">
          <div class="card-header"><h3>Global Market Intelligence</h3><p>Live crypto, equity, and headline feeds</p></div>
          <div id="market-strip" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px"><div class="loading">Acquiring market telemetry...</div></div>
        </div>
        <div class="home-bottom">
          <div class="card" style="flex:1"><div class="card-header"><h3>Recent Activity</h3></div><div id="home-activity"></div></div>
          <div class="card" style="flex:1;min-width:280px"><div class="card-header"><h3>Quick Stats</h3></div><div id="home-quick-stats" class="kpi-grid" style="margin:0"></div></div>
        </div>
      </section>

      <section class="page" id="page-dashboard">
        <div class="kpi-grid" id="kpi-grid"></div>
        <div class="card" style="border-top-color:var(--gold);margin-bottom:18px">
          <div class="card-header"><h3>Live Market Intelligence</h3><p>Crypto, equities, and breaking headlines</p></div>
          <div id="dashboard-market-strip" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px"><div class="loading">Acquiring market telemetry...</div></div>
        </div>
        <div class="chart-grid">
          <div class="card"><div class="card-header"><h3>Revenue vs Expenses</h3><p>Last 6 months</p></div><canvas id="rev-chart" class="chart-canvas"></canvas></div>
          <div class="card"><div class="card-header"><h3>Sales Pipeline</h3><p>By stage</p></div><canvas id="pipe-chart" class="chart-canvas"></canvas></div>
        </div>
        <div class="chart-grid">
          <div class="card"><div class="card-header"><h3>Daily Cash Balance</h3><p>Last 30 days</p></div><canvas id="cash-chart" class="chart-canvas"></canvas></div>
          <div class="card"><div class="card-header"><h3>Order Fulfillment</h3><p>Status breakdown</p></div><canvas id="fulfill-chart" class="chart-canvas"></canvas></div>
        </div>
        <div class="card">
          <div class="card-header"><h3>Recent Activity</h3><p>Live feed from operations</p></div>
          <div id="activity-feed"></div>
        </div>
      </section>

      <section class="page" id="page-sales">
        <div class="toolbar"><input type="text" id="sales-search" placeholder="Search deals…" /><div class="toolbar-right"><button class="btn btn-primary" data-action="add-deal"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Add Deal</button></div></div>
        <div class="card" style="padding:0"><div class="table-wrap"><table id="sales-table"><thead><tr><th>Customer</th><th>Deal</th><th>Value</th><th>Stage</th><th>Owner</th><th>Close</th><th></th></tr></thead><tbody></tbody></table></div></div>
      </section>

      <section class="page" id="page-orders">
        <div class="toolbar"><input type="text" id="orders-search" placeholder="Search orders…" /><div class="toolbar-right"><button class="btn btn-primary" data-action="add-order"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Add Order</button></div></div>
        <div class="card" style="padding:0"><div class="table-wrap"><table id="orders-table"><thead><tr><th>Customer</th><th>SKU</th><th>Qty</th><th>Status</th><th>Ship Date</th><th>Tracking</th><th></th></tr></thead><tbody></tbody></table></div></div>
      </section>

      <section class="page" id="page-employees">
        <div class="toolbar"><input type="text" id="emp-search" placeholder="Search employees…" /><div class="toolbar-right"><button class="btn btn-primary" data-action="add-emp"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Add Employee</button></div></div>
        <div class="card" style="padding:0"><div class="table-wrap"><table id="emp-table"><thead><tr><th>Name</th><th>Role</th><th>Department</th><th>Status</th><th>Salary</th><th></th></tr></thead><tbody></tbody></table></div></div>
      </section>

      <section class="page" id="page-finance">
        <div class="toolbar"><input type="text" id="fin-search" placeholder="Search invoices…" /><div class="toolbar-right"><button class="btn btn-primary" data-action="add-inv"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Add Invoice</button></div></div>
        <div class="card" style="padding:0"><div class="table-wrap"><table id="fin-table"><thead><tr><th>#</th><th>Client</th><th>Amount</th><th>Due</th><th>Status</th><th></th></tr></thead><tbody></tbody></table></div></div>
      </section>

      <section class="page" id="page-inventory">
        <div class="toolbar"><input type="text" id="inv-search" placeholder="Search products…" /><div class="toolbar-right"><button class="btn btn-primary" data-action="add-prod"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Add Product</button></div></div>
        <div class="card" style="padding:0"><div class="table-wrap"><table id="inv-table"><thead><tr><th>Product</th><th>SKU</th><th>Category</th><th>Stock</th><th>Price</th><th></th></tr></thead><tbody></tbody></table></div></div>
      </section>

      <section class="page" id="page-entities">
        <div class="toolbar"><input type="text" id="ent-search" placeholder="Search entities…" /><div class="toolbar-right"><button class="btn btn-primary" data-action="add-ent"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Add Entity</button></div></div>
        <div class="card" style="padding:0"><div class="table-wrap"><table id="ent-table"><thead><tr><th>Name</th><th>Country</th><th>Currency</th><th>Active</th><th></th></tr></thead><tbody></tbody></table></div></div>
      </section>

      <section class="page" id="page-accounting">
        <div class="kpi-grid" id="acct-kpis"></div>
        <div class="toolbar"><input type="text" id="acct-search" placeholder="Search accounts…" /><div class="toolbar-right"><button class="btn btn-primary" data-action="add-acct"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Add Account</button> <button class="btn btn-ghost" data-action="add-je"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Journal Entry</button></div></div>
        <div class="card" style="padding:0"><div class="table-wrap"><table id="acct-table"><thead><tr><th>Code</th><th>Name</th><th>Type</th><th>Balance</th><th></th></tr></thead><tbody></tbody></table></div></div>
        <div class="card" style="padding:0;margin-top:22px"><div class="card-header" style="padding:20px 22px 0"><h3>Journal Entries</h3></div><div class="table-wrap"><table id="je-table"><thead><tr><th>Date</th><th>Description</th><th>Debit</th><th>Credit</th><th>Amount</th><th></th></tr></thead><tbody></tbody></table></div></div>
        <div class="kpi-grid" style="margin-top:22px" id="fs-kpis"></div>
        <div class="card"><div class="card-header"><h3>Balance Sheet</h3></div><div class="kpi-grid" id="bs-kpis"></div></div>
      </section>

      <section class="page" id="page-projects">
        <div class="toolbar"><input type="text" id="proj-search" placeholder="Search projects…" /><div class="toolbar-right"><button class="btn btn-primary" data-action="add-proj"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Add Project</button></div></div>
        <div id="projects-list" style="display:flex;flex-direction:column;gap:18px"></div>
      </section>

      <section class="page" id="page-analytics">
        <div class="kpi-grid" id="analytics-kpis"></div>
        <div class="chart-grid">
          <div class="card"><div class="card-header"><h3>Revenue by Category</h3><p>Quarterly breakdown</p></div><canvas id="cat-chart" class="chart-canvas"></canvas></div>
          <div class="card"><div class="card-header"><h3>Team Performance</h3><p>Deals closed per rep</p></div><canvas id="team-chart" class="chart-canvas"></canvas></div>
        </div>
      </section>

      <section class="page" id="page-banking">
        <div class="provider-tabs">
          <button class="provider-tab active" data-provider="plaid">Plaid (US / Canada)</button>
          <button class="provider-tab" data-provider="truelayer">TrueLayer (UK / EU Open Banking)</button>
        </div>
        <div id="banking-status" class="loading" style="display:none"></div>

        <div class="provider-panel" id="panel-plaid">
          <div class="toolbar"><div class="toolbar-right"><button class="btn btn-primary" id="plaid-link-btn"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Connect Bank via Plaid</button></div></div>
          <div class="card" id="plaid-accounts-card" style="display:none"><div class="card-header"><h3>Plaid Connected Accounts</h3></div><div class="table-wrap"><table id="plaid-accounts-table"><thead><tr><th>Institution</th><th>Account</th><th>Type</th><th>Available</th><th>Current</th></tr></thead><tbody></tbody></table></div></div>
          <div class="card" id="plaid-transactions-card" style="display:none;margin-top:22px"><div class="card-header"><h3>Plaid Recent Transactions</h3></div><div class="table-wrap"><table id="plaid-transactions-table"><thead><tr><th>Date</th><th>Name</th><th>Amount</th><th>Category</th></tr></thead><tbody></tbody></table></div></div>
        </div>

        <div class="provider-panel" id="panel-truelayer" style="display:none">
          <div class="toolbar"><div class="toolbar-right"><button class="btn btn-primary" id="truelayer-link-btn"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Connect Bank via TrueLayer</button></div></div>
          <div class="card" id="truelayer-accounts-card" style="display:none"><div class="card-header"><h3>TrueLayer Connected Accounts</h3></div><div class="table-wrap"><table id="truelayer-accounts-table"><thead><tr><th>Provider</th><th>Account</th><th>Type</th><th>Currency</th></tr></thead><tbody></tbody></table></div></div>
          <div class="card" id="truelayer-transactions-card" style="display:none;margin-top:22px"><div class="card-header"><h3>TrueLayer Recent Transactions</h3></div><div class="table-wrap"><table id="truelayer-transactions-table"><thead><tr><th>Date</th><th>Name</th><th>Amount</th><th>Category</th></tr></thead><tbody></tbody></table></div></div>
        </div>
      </section>

      <section class="page" id="page-trading">
        <div class="toolbar">
          <div class="toolbar-right">
            <button class="btn btn-ghost" id="freqtrade-refresh"><svg class="icon" aria-hidden="true"><use href="#icon-refresh-cw"></use></svg> Refresh</button>
            <button class="btn btn-success" id="freqtrade-start" disabled><svg class="icon icon-fill" aria-hidden="true"><use href="#icon-play"></use></svg> Start</button>
            <button class="btn btn-danger" id="freqtrade-stop" disabled><svg class="icon icon-fill" aria-hidden="true"><use href="#icon-square"></use></svg> Stop</button>
          </div>
        </div>
        <div id="freqtrade-status" class="loading" style="display:none"></div>
        <div id="freqtrade-kpis" class="kpi-grid" style="display:none;margin-bottom:22px">
          <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-activity"></use></svg></div><div class="kpi-label">Bot State</div><div class="kpi-value" id="ft-state">—</div></div>
          <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-dollar-sign"></use></svg></div><div class="kpi-label">Total Profit</div><div class="kpi-value" id="ft-profit">—</div></div>
          <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-bar-chart"></use></svg></div><div class="kpi-label">Win Rate</div><div class="kpi-value" id="ft-win">—</div></div>
          <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-credit-card"></use></svg></div><div class="kpi-label">Balance</div><div class="kpi-value" id="ft-balance">—</div></div>
        </div>
