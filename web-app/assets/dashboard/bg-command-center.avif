      <div class="form-group"><label>New Password</label><input type="password" id="new-password" placeholder="Min 8 chars, upper/lower/digit/special" /></div>
      <div class="form-group"><label>Confirm New Password</label><input type="password" id="confirm-password" /></div>
      <button type="submit" class="btn btn-primary" style="width:100%">Save Changes</button>
    </form>
  </div>
</div>

<script>
if ('serviceWorker' in navigator) navigator.serviceWorker.register('/service-worker.js').catch(()=>{});
const API = '';
let currentPage = 'home';
let editingId = null, editingType = null;
let entitiesCache = [];
let accountsCache = [];
let projectsCache = [];

async function api(path, opts = {}) {
  opts.credentials = 'include';
  if (opts.body && typeof opts.body === 'object' && !(opts.body instanceof FormData)) {
    opts.headers = { ...opts.headers, 'Content-Type': 'application/json' };
    opts.body = JSON.stringify(opts.body);
  }
  const res = await fetch(API + path, opts);
  const text = await res.text();
  let data;
  try { data = JSON.parse(text); } catch { data = { ok: false, error: text }; }
  return { status: res.status, data };
}

function format$(n) { return '$' + Math.round(n).toLocaleString(); }
function fmtDate(d) { return d ? new Date(d).toLocaleDateString() : '—'; }
function icon(name, cls = '') { return `<svg class="icon ${cls}" aria-hidden="true"><use href="#icon-${name}"></use></svg>`; }

function badge(text) {
  const t = text.toLowerCase().replace(/\s/g,'-');
  return `<span class="badge badge-${t}">${text}</span>`;
}

function cssColor(name) { return getComputedStyle(document.documentElement).getPropertyValue(name).trim(); }

function drawLineChart(canvas, labels, series) {
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * dpr; canvas.height = rect.height * dpr;
  ctx.scale(dpr, dpr);
  const w = rect.width, h = rect.height, pad = 34;
  ctx.clearRect(0, 0, w, h);
  const allVals = series.flatMap(s => s.data);
  const max = Math.max(...allVals, 1) * 1.1;
  const stepX = (w - pad * 2) / (labels.length - 1);
  series.forEach(s => {
    ctx.beginPath(); ctx.strokeStyle = s.color; ctx.lineWidth = 3; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
    s.data.forEach((v, i) => { const x = pad + i * stepX; const y = h - pad - (v / max) * (h - pad * 2); if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y); });
    ctx.stroke();
  });
  ctx.fillStyle = cssColor('--text-muted'); ctx.font = '11px sans-serif'; ctx.textAlign = 'center';
  labels.forEach((l, i) => { if (i % Math.ceil(labels.length/6) === 0) ctx.fillText(l, pad + i * stepX, h - 10); });
  let lx = w - 120;
  series.forEach(s => { ctx.fillStyle = s.color; ctx.beginPath(); ctx.arc(lx, 16, 5, 0, Math.PI * 2); ctx.fill(); ctx.fillStyle = cssColor('--text'); ctx.fillText(s.label, lx + 12, 20); lx += 70; });
}

function drawBarChart(canvas, labels, data, colors) {
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * dpr; canvas.height = rect.height * dpr;
  ctx.scale(dpr, dpr);
  const w = rect.width, h = rect.height, pad = 34;
  ctx.clearRect(0, 0, w, h);
  const max = Math.max(...data, 1) * 1.1;
  const stepX = (w - pad * 2) / labels.length;
  const barW = stepX * 0.55;
  data.forEach((v, i) => {
    const x = pad + i * stepX + (stepX - barW) / 2;
    const barH = (v / max) * (h - pad * 2);
    const y = h - pad - barH;
    ctx.fillStyle = colors[i % colors.length] || cssColor('--blue');
    ctx.fillRect(x, y, barW, barH);
  });
  ctx.fillStyle = cssColor('--text-muted'); ctx.font = '11px sans-serif'; ctx.textAlign = 'center';
  labels.forEach((l, i) => { ctx.fillText(l, pad + i * stepX + stepX / 2, h - 10); });
}

async function loadEntities() {
  const [{ data: ent }, { data: acc }, { data: proj }] = await Promise.all([api('/api/entities'), api('/api/accounts'), api('/api/projects')]);
  entitiesCache = ent || [];
  accountsCache = acc || [];
  projectsCache = proj || [];
  const sel = document.getElementById('entity-select');
  sel.innerHTML = entitiesCache.map(e => `<option value="${e.id}" ${e.id === 1 ? 'selected' : ''}>${e.name}</option>`).join('');
  sel.insertAdjacentHTML('afterbegin', '<option value="0">All Entities</option>');
}

async function setEntity(id) {
  await api('/api/set-entity', { method: 'POST', body: { entity_id: id } });
  switchPage(currentPage);
}

const appTiles = [
  { page: 'dashboard', icon: 'layout', title: 'Dashboard', desc: 'KPIs, charts & activity', count: null },
  { page: 'sales', icon: 'briefcase', title: 'Sales / CRM', desc: 'Deals & pipeline', count: 'open_deals' },
  { page: 'orders', icon: 'truck', title: 'Orders', desc: 'Fulfillment & tracking', count: 'pending_orders' },
  { page: 'employees', icon: 'users', title: 'Employees', desc: 'Team directory', count: 'active_employees' },
  { page: 'finance', icon: 'credit-card', title: 'Finance', desc: 'Invoices & receivables', count: 'open_invoices' },
  { page: 'inventory', icon: 'package', title: 'Inventory', desc: 'Stock & products', count: 'low_stock' },
  { page: 'entities', icon: 'globe', title: 'Entities', desc: 'Subsidiaries & global ops', count: null },
  { page: 'accounting', icon: 'book-open', title: 'Accounting', desc: 'GL, P&L & balance sheet', count: null },
  { page: 'projects', icon: 'folder', title: 'Projects', desc: 'Projects & tasks', count: 'active_projects' },
  { page: 'analytics', icon: 'bar-chart', title: 'Analytics', desc: 'Reports & team metrics', count: null },
  { page: 'ai', icon: 'cpu', title: 'AI Assistant', desc: 'Ask natural-language questions', count: null },
  { page: 'casino', icon: 'dice', title: 'Casino', desc: 'Live casino floor & stats', count: null }
];

async function updateCommandBar() {
  try {
    const { data } = await api('/api/dashboard');
    if (!data.ok) return;
    const k = data.kpis;
    document.getElementById('command-cash').textContent = format$(k.cash_balance);
    document.getElementById('command-deals').textContent = k.open_deals;
    const alerts = (k.overdue_count || 0) + (k.low_stock || 0);
    document.getElementById('command-alerts').textContent = alerts;
    document.getElementById('sys-status-text').textContent = 'OPERATIONAL';
    document.getElementById('sys-status-light').className = 'status-light';
    document.getElementById('cash-light').className = 'status-light' + (k.cash_balance > 500000 ? '' : ' amber');
    document.getElementById('deals-light').className = 'status-light' + (k.open_deals > 5 ? ' amber' : '');
    document.getElementById('alert-light').className = 'status-light' + (alerts > 0 ? ' red' : '');
  } catch (e) {
    document.getElementById('sys-status-text').textContent = 'DEGRADED';
    document.getElementById('sys-status-light').className = 'status-light red';
  }
}

function updateMissionClock() {
  const el = document.getElementById('mission-clock');
  if (el) el.textContent = new Date().toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
}
setInterval(updateMissionClock, 1000);

function pctColor(n) { return n >= 0 ? 'var(--green)' : 'var(--red)'; }
function pctArrow(n) { return n >= 0 ? '▲' : '▼'; }

async function loadMarketStrip(containerId='market-strip') {
  const el = document.getElementById(containerId);
  if (!el) return;
  try {
    const [{ data: crypto }, { data: stocks }, { data: news }] = await Promise.all([
      api('/api/market/crypto'), api('/api/market/stocks'), api('/api/market/news')
    ]);
    let html = '';
    if (crypto && crypto.crypto) {
      html += `<div class="card" style="background:rgba(0,0,0,0.2);padding:12px"><div style="font-size:0.65rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px">Crypto</div>` + crypto.crypto.slice(0,5).map(c => {
        const ch = c.price_change_percentage_24h || 0;
        return `<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--border)"><span><img src="${c.image}" style="width:14px;height:14px;border-radius:50%;vertical-align:middle;margin-right:6px">${c.symbol.toUpperCase()}</span><span style="color:${pctColor(ch)}">${format$(c.current_price)} ${pctArrow(ch)}${Math.abs(ch).toFixed(1)}%</span></div>`;
      }).join('') + `</div>`;
    }
    if (stocks && stocks.ok && stocks.stocks) {
      html += `<div class="card" style="background:rgba(0,0,0,0.2);padding:12px"><div style="font-size:0.65rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px">Equities</div>` + ['^GSPC','BTC-USD','ETH-USD','AAPL','TSLA','NVDA'].map(s => {
        const d = stocks.stocks[s] || {}; if (d.error) return '';
        const ch = d.pct || 0; const label = s.replace('^','');
        return `<div style="display:flex;justify-content:space-between;padding:5px 0;border-bottom:1px solid var(--border)"><span>${label}</span><span style="color:${pctColor(ch)}">${format$(d.price)} ${pctArrow(ch)}${Math.abs(ch).toFixed(1)}%</span></div>`;
      }).filter(Boolean).join('') + `</div>`;
    }
    if (news && news.news) {
      html += `<div class="card" style="background:rgba(0,0,0,0.2);padding:12px"><div style="font-size:0.65rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px">Headlines</div><div class="log" style="max-height:130px;overflow-y:auto">` + news.news.slice(0,5).map(n => `<div style="padding:5px 0;border-bottom:1px solid var(--border);font-size:0.82rem"><span style="color:var(--gold);text-transform:uppercase;font-size:0.6rem">${n.source}</span> ${n.title}</div>`).join('') + `</div></div>`;
    }
    el.innerHTML = html || 'Market telemetry unavailable';
  } catch (e) { el.innerHTML = '<div class="loading">Market feed offline</div>'; }
}

async function loadHome() {
  const [{ data: dash }, { data: emp }, { data: orders }, { data: projects }] = await Promise.all([
    api('/api/dashboard'), api('/api/employees'), api('/api/orders'), api('/api/projects')
  ]);
  if (!dash.ok) return;
  const user = await api('/api/me');
  const entityName = entitiesCache.find(e => e.id == (user.data.entity || 1))?.name || 'All Entities';
  document.getElementById('home-title').textContent = 'GOAT FORCE COMMAND';
  document.getElementById('home-subtitle').textContent = `Commander: ${user.data.user.name} · ${user.data.user.role === 'admin' ? 'Administrator' : 'User'} · ${entityName}`;

  const quick = {
    open_deals: dash.kpis.open_deals,
    pending_orders: orders.filter(o => o.status === 'Pending' || o.status === 'Picked').length,
    active_employees: emp.filter(e => e.status === 'Active').length,
    open_invoices: emp.length ? 0 : 0, // placeholder, will set below
    low_stock: dash.kpis.low_stock,
    active_projects: projects.filter(p => p.status === 'In Progress').length
  };
  const openInvoices = await api('/api/invoices?status=Open');
  quick.open_invoices = openInvoices.data.filter(i => i.status === 'Open' || i.status === 'Overdue').length;

  document.getElementById('app-tiles').innerHTML = appTiles.map(t => {
    const c = quick[t.count] !== undefined ? quick[t.count] : '';
    const countHtml = c !== '' ? `<div class="tile-count">${typeof c === 'number' && c > 999 ? (c/1000).toFixed(1)+'k' : c}</div>` : '';
    const isExternal = t.external;
    const tag = isExternal ? 'a' : 'div';
    const href = isExternal ? ` href="${t.external}" target="_blank" rel="noopener"` : '';
    const pageAttr = isExternal ? '' : ` data-page="${t.page}"`;
    return `
    <${tag} class="app-tile"${pageAttr}${href}>
      <div class="app-tile-icon">${icon(t.icon, 'icon-lg')}</div>
      <div><h4>${t.title}</h4><p>${t.desc}</p></div>
      ${countHtml}
    </${tag}>`;
  }).join('');

  document.getElementById('home-activity').innerHTML = dash.activity.map(a =>
    `<div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);font-size:0.9rem"><span>${a.text}</span><span style="color:var(--text-muted);font-size:0.8rem">${a.time}</span></div>`
  ).join('');

  document.getElementById('home-quick-stats').innerHTML = `
    <div class="kpi"><div class="kpi-label">Revenue</div><div class="kpi-value">${format$(dash.kpis.revenue)}</div></div>
    <div class="kpi"><div class="kpi-label">Cash</div><div class="kpi-value">${format$(dash.kpis.cash_balance)}</div></div>
    <div class="kpi"><div class="kpi-label">Outstanding</div><div class="kpi-value">${format$(dash.kpis.outstanding_invoices)}</div></div>`;
  loadMarketStrip('market-strip');
  await updateCommandBar();
}

async function loadDashboard() {
  const { data } = await api('/api/dashboard');
  if (!data.ok) return;
  const k = data.kpis;
  document.getElementById('kpi-grid').innerHTML = `
    <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-dollar-sign"></use></svg></div><div class="kpi-label">6-Month Revenue</div><div class="kpi-value">${format$(k.revenue)}</div><div class="kpi-delta up">${icon('arrow-up')} +18% vs prior</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('briefcase','icon-lg')}</div><div class="kpi-label">Open Deals</div><div class="kpi-value">${k.open_deals}</div><div class="kpi-delta up">${format$(k.total_deal_value)} total value</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('file-text','icon-lg')}</div><div class="kpi-label">Outstanding Invoices</div><div class="kpi-value">${format$(k.outstanding_invoices)}</div><div class="kpi-delta down">${icon('arrow-down')} ${k.overdue_count} overdue</div></div>
    <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-credit-card"></use></svg></div><div class="kpi-label">Cash Balance</div><div class="kpi-value">${format$(k.cash_balance)}</div><div class="kpi-delta up">${icon('arrow-up')} Daily visibility</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('package','icon-lg')}</div><div class="kpi-label">Low Stock Items</div><div class="kpi-value">${k.low_stock}</div><div class="kpi-delta down">${icon('arrow-down')} Re-order soon</div></div>`;
  requestAnimationFrame(() => {
    drawLineChart(document.getElementById('rev-chart'), data.monthly.map(m => m.month), [
      { label: 'Revenue', data: data.monthly.map(m => m.revenue), color: cssColor('--gold') },
      { label: 'Expenses', data: data.monthly.map(m => m.expenses), color: cssColor('--red') }
    ]);
    drawBarChart(document.getElementById('pipe-chart'), data.pipeline.map(p => p.label), data.pipeline.map(p => p.value), [cssColor('--blue')]);
    drawLineChart(document.getElementById('cash-chart'), data.cash.map(c => c.date.slice(5)), [
      { label: 'Cash', data: data.cash.map(c => c.balance), color: cssColor('--green') }
    ]);
  });
  // Fulfillment chart
  const fulfill = { 'Pending': 0, 'Picked': 0, 'Shipped': 0, 'Delivered': 0 };
  const { data: orders } = await api('/api/orders');
  orders.forEach(o => { if (fulfill[o.status] !== undefined) fulfill[o.status]++; });
  drawBarChart(document.getElementById('fulfill-chart'), Object.keys(fulfill), Object.values(fulfill), [cssColor('--blue'), cssColor('--orange'), cssColor('--gold'), cssColor('--green')]);
  document.getElementById('activity-feed').innerHTML = data.activity.map(a =>
    `<div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--border);font-size:0.9rem"><span>${a.text}</span><span style="color:var(--text-muted);font-size:0.8rem">${a.time}</span></div>`
  ).join('');
  loadMarketStrip('dashboard-market-strip');
  await updateCommandBar();
}

function renderTable(tableId, rows, fn) {
  const tbody = document.querySelector(`#${tableId} tbody`);
  if (!rows || !rows.length) { tbody.innerHTML = '<tr><td colspan="10" class="loading">No records found.</td></tr>'; return; }
  tbody.innerHTML = rows.map(fn).join('');
}

async function loadSales(q = '') {
  const { data } = await api('/api/deals' + (q ? `?q=${encodeURIComponent(q)}` : ''));
  renderTable('sales-table', data, d => `
    <tr data-id="${d.id}" data-type="deal">
      <td>${d.customer}</td><td>${d.name}</td><td>${format$(d.value)}</td><td>${badge(d.stage)}</td><td>${d.owner}</td><td>${fmtDate(d.close)}</td>
      <td><button class="btn btn-ghost btn-sm" data-action="edit" data-id="${d.id}" data-type="deal">Edit</button> <button class="btn btn-danger btn-sm" data-action="delete" data-id="${d.id}" data-type="deal">${icon('trash')}</button></td>
    </tr>`);
}
