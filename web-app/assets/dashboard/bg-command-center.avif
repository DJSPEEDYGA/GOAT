// Plaid Link bank connect
document.getElementById('plaid-link-btn').addEventListener('click', async () => {
  const { data } = await api('/api/plaid/link_token', { method: 'POST' });
  if (!data.ok) { alert(data.error || 'Could not start Plaid Link'); return; }
  const handler = Plaid.create({
    token: data.link_token,
    onSuccess: async (public_token, metadata) => {
      const { data: ex } = await api('/api/plaid/exchange', { method: 'POST', body: { public_token } });
      if (ex.ok) loadBanking();
      else alert(ex.error || 'Bank connect failed');
    },
    onExit: (err) => { if (err) console.error(err); }
  });
  handler.open();
});

// TrueLayer open banking connect
document.getElementById('truelayer-link-btn').addEventListener('click', async () => {
  const { data } = await api('/api/truelayer/connect', { method: 'POST' });
  if (!data.ok) { alert(data.error || 'Could not start TrueLayer'); return; }
  const w = window.open(data.url, 'truelayer', 'width=600,height=700');
  const onMsg = e => {
    if (e.data && e.data.type === 'truelayer') {
      window.removeEventListener('message', onMsg);
      if (w && !w.closed) w.close();
      if (e.data.status === 'connected') {
        loadBanking();
      } else if (e.data.error) {
        alert('TrueLayer error: ' + e.data.error);
      }
    }
  };
  window.addEventListener('message', onMsg);
});

// Royalty Command tabs & tools
async function digestSha256(buf) {
  const hash = await crypto.subtle.digest('SHA-256', buf);
  return Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2,'0')).join('');
}
async function hashTextOrFile() {
  const input = document.getElementById('vault-hash-input');
  const files = input.files;
  let buf, label;
  if (files && files.length) {
    buf = await files[0].arrayBuffer();
    label = files[0].name;
  } else {
    buf = new TextEncoder().encode(input.value || '');
    label = 'evidence-text';
  }
  const hash = await digestSha256(buf);
  const out = `SHA-256: ${hash}\nSource: ${label}\nTimestamp: ${new Date().toISOString()}`;
  document.getElementById('vault-hash-output').textContent = out;
  document.getElementById('vault-hash-output').dataset.hash = hash;
}
async function exportSurvivor() {
  const hash = document.getElementById('vault-hash-output').dataset.hash || '';
  const input = document.getElementById('vault-hash-input').value || '';
  const payload = {
    evidence: input.slice(0, 500),
    hash: hash,
    noticeTimestamp: new Date().toISOString(),
    survivorNote: 'I am a builder. I am a survivor.',
    empire: 'GOAT Force Records',
    owner: 'DJ Speedy (Harvey L. Miller Jr.)'
  };
  const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `goat-survivor-${new Date().toISOString().split('T')[0]}.json`;
  a.click();
  URL.revokeObjectURL(url);
}
async function sendCodex() {
  const input = document.getElementById('codex-input');
  const chat = document.getElementById('codex-chat');
  const q = input.value.trim();
  if (!q) return;
  chat.innerHTML += `<div class="ai-msg user" style="align-self:flex-end;background:rgba(163,198,68,0.12);border:1px solid var(--green);padding:10px 14px;border-radius:12px;max-width:80%">${escapeHtml(q)}</div>`;
  input.value = '';
  chat.scrollTop = chat.scrollHeight;
  const { data } = await api('/api/ai/codex', { method: 'POST', body: { prompt: q } });
  const reply = data.ok ? (data.answer || 'Codex is thinking…') : ('Codex error: ' + (data.error || 'AI unavailable'));
  chat.innerHTML += `<div class="ai-msg bot" style="align-self:flex-start;background:rgba(0,0,0,0.35);border:1px solid var(--border);padding:10px 14px;border-radius:12px;max-width:80%">${escapeHtml(reply)}</div>`;
  chat.scrollTop = chat.scrollHeight;
}
async function calcGift() {
  const sale = parseFloat(document.getElementById('gift-sale').value) || 0;
  const rate = parseFloat(document.getElementById('gift-rate').value) || 0;
  const { data } = await api('/api/royalty_calc', { method: 'POST', body: { sale, rate } });
  const royalty = data.royalty || (sale * rate);
  const platform = royalty * 0.10;
  const creator = royalty * 0.70;
  const investors = royalty * 0.20;
  document.getElementById('gift-output').innerHTML = `
    <div class="kpi-grid" style="margin:0">
      <div class="kpi"><div class="kpi-label">Gross Sale</div><div class="kpi-value">${format$(sale)}</div></div>
      <div class="kpi"><div class="kpi-label">Total Royalty</div><div class="kpi-value">${format$(royalty)}</div></div>
      <div class="kpi"><div class="kpi-label">Creator Empowerment (70%)</div><div class="kpi-value" style="color:var(--green)">${format$(creator)}</div></div>
      <div class="kpi"><div class="kpi-label">Investors (20%)</div><div class="kpi-value">${format$(investors)}</div></div>
      <div class="kpi"><div class="kpi-label">Platform (10%)</div><div class="kpi-value">${format$(platform)}</div></div>
    </div>`;
}
function escapeHtml(s) {
  const div = document.createElement('div');
  div.textContent = s;
  return div.innerHTML;
}

document.querySelectorAll('.royalty-tab').forEach(btn => btn.addEventListener('click', () => showRoyaltyPanel(btn.dataset.royalty)));
document.getElementById('vault-hash-btn').addEventListener('click', hashTextOrFile);
document.getElementById('vault-export-btn').addEventListener('click', exportSurvivor);
