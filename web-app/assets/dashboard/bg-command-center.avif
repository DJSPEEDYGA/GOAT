  ],
  journal_entry: [
    { name: 'date', label: 'Date', type: 'date', required: true },
    { name: 'description', label: 'Description', type: 'text', required: true },
    { name: 'debit_account', label: 'Debit Account', type: 'select', optionsFrom: 'accounts' },
    { name: 'credit_account', label: 'Credit Account', type: 'select', optionsFrom: 'accounts' },
    { name: 'amount', label: 'Amount', type: 'number', required: true }
  ],
  project: [
    { name: 'name', label: 'Project Name', type: 'text', required: true },
    { name: 'budget', label: 'Budget', type: 'number', required: true },
    { name: 'status', label: 'Status', type: 'select', options: ['Planning','In Progress','On Hold','Done'] },
    { name: 'start_date', label: 'Start Date', type: 'date', required: false },
    { name: 'end_date', label: 'End Date', type: 'date', required: false },
