  ],
  task: [
    { name: 'project_id', label: 'Project', type: 'select', optionsFrom: 'projects' },
    { name: 'name', label: 'Task Name', type: 'text', required: true },
    { name: 'status', label: 'Status', type: 'select', options: ['Todo','In Progress','Done'] },
    { name: 'assigned_to', label: 'Assigned To', type: 'text', required: false },
    { name: 'due_date', label: 'Due Date', type: 'date', required: false }
  ]
