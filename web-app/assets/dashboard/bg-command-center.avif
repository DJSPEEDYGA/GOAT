    <div class="modal-header"><h3>Profile & Security</h3><button class="close-modal" id="close-profile-modal"><svg class="icon" aria-hidden="true"><use href="#icon-x"></use></svg></button></div>
    <form id="profile-form">
      <div class="form-group"><label>Email</label><input type="email" name="email" id="profile-email" required /></div>
