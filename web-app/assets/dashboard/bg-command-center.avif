const typeEndpoints = { deal: 'deals', employee: 'employees', invoice: 'invoices', product: 'inventory', order: 'orders', entity: 'entities', account: 'accounts', journal_entry: 'journal_entries', project: 'projects', task: 'tasks' };

async function openModal(type, id = null) {
  editingType = type; editingId = id;
  const schema = formSchemas[type];
  const title = (id ? 'Edit ' : 'Add ') + type.charAt(0).toUpperCase() + type.slice(1);
  document.getElementById('modal-title').textContent = title;
  const form = document.getElementById('modal-form');
  form.innerHTML = '';
  let item = {};
  if (id) {
    const { data } = await api(`/api/${typeEndpoints[type]}/${id}`);
    item = data || {};
  }
  for (const field of schema) {
    const value = item[field.name] !== undefined ? item[field.name] : '';
    let input;
    if (field.type === 'select') {
      let opts = '';
      if (field.optionsFrom === 'entities') opts = entitiesCache.map(e => `<option value="${e.id}" ${value == e.id ? 'selected' : ''}>${e.name}</option>`).join('');
      else if (field.optionsFrom === 'accounts') opts = accountsCache.map(a => `<option value="${a.id}" ${value == a.id ? 'selected' : ''}>${a.code} - ${a.name}</option>`).join('');
      else if (field.optionsFrom === 'projects') opts = projectsCache.map(p => `<option value="${p.id}" ${value == p.id ? 'selected' : ''}>${p.name}</option>`).join('');
      else opts = field.options.map(o => `<option value="${o}" ${value == o ? 'selected' : ''}>${o}</option>`).join('');
      input = `<select name="${field.name}" ${field.required ? 'required' : ''}>${opts}</select>`;
    } else {
      input = `<input type="${field.type}" name="${field.name}" value="${value}" ${field.required ? 'required' : ''} />`;
    }
    form.insertAdjacentHTML('beforeend', `<div class="form-group"><label>${field.label}</label>${input}</div>`);
  }
  form.insertAdjacentHTML('beforeend', `<button type="submit" class="btn btn-primary" style="width:100%">Save ${type}</button>`);
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); editingId = null; editingType = null; }

document.getElementById('modal-form').addEventListener('submit', async e => {
  e.preventDefault();
  const fd = new FormData(e.target);
  const data = Object.fromEntries(fd.entries());
  const numeric = ['value','salary','amount','stock','price','qty','entity_id','active','debit_account','credit_account','budget','project_id'];
  numeric.forEach(f => { if (data[f] !== undefined && data[f] !== '') data[f] = Number(data[f]); });
  const ep = typeEndpoints[editingType];
  if (!ep) { alert('Unknown record type: ' + editingType); return; }
  const method = editingId ? 'PUT' : 'POST';
  const path = editingId ? `/api/${ep}/${editingId}` : `/api/${ep}`;
  const result = await api(path, { method, body: data });
  if (!result.data || !result.data.ok) { alert('Save failed: ' + (result.data && result.data.error ? result.data.error : 'unknown error')); return; }
  closeModal();
  if (['entity','account','project'].includes(editingType)) await loadEntities();
  switchPage(currentPage);
});

async function deleteItem(type, id) {
  if (!confirm('Delete this ' + type + '?')) return;
  const { data } = await api(`/api/${typeEndpoints[type]}/${id}`, { method: 'DELETE' });
  if (!data || !data.ok) { alert('Delete failed: ' + (data && data.error ? data.error : 'unknown error')); return; }
  if (['entity','account','project'].includes(type)) await loadEntities();
  switchPage(currentPage);
}

// Event wiring
document.querySelectorAll('#nav button').forEach(btn => btn.addEventListener('click', () => switchPage(btn.dataset.page)));

document.getElementById('login-form').addEventListener('submit', async e => {
  e.preventDefault();
  document.getElementById('login-error').classList.remove('show');
  const btn = document.getElementById('login-btn');
  btn.disabled = true; btn.textContent = 'Signing in…';
  const { data } = await api('/api/login', {
    method: 'POST',
    body: { email: document.getElementById('login-email').value.trim().toLowerCase(), password: document.getElementById('login-pass').value }
  });
  btn.disabled = false; btn.textContent = 'Enter command center';
  if (data.ok) {
    document.getElementById('login-view').style.display = 'none';
    document.getElementById('app-view').classList.add('active');
    document.getElementById('user-info').textContent = data.user.name;
    await loadEntities();
    switchPage('home');
  } else {
    document.getElementById('login-error').classList.add('show');
  }
});

