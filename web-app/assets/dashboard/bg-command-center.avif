}

async function loadCasino() {
  const { data: stats } = await api('/api/casino/stats');
  const { data: games } = await api('/api/casino/games?q=');
  if (stats && stats.ok) {
    const fmt = n => n == null ? '—' : Number(n).toLocaleString();
    document.getElementById('casino-stats').innerHTML = `
      <div class="stat"><span class="value">\$${fmt(stats.total_daily_revenue)}</span><span class="label">Daily Revenue</span></div>
      <div class="stat"><span class="value">${fmt(stats.total_players)}</span><span class="label">Active Players</span></div>
      <div class="stat"><span class="value">${fmt((stats.categories || []).length)}</span><span class="label">Categories</span></div>
      <div class="stat"><span class="value">${fmt((games.games || []).length)}</span><span class="label">Games</span></div>
    `;
  }
  const floor = document.getElementById('casino-floor');
  if (floor && games && games.ok) {
    floor.innerHTML = games.games.slice(0, 12).map(g => `
      <div class="card" style="padding:14px;display:flex;justify-content:space-between;align-items:center">
        <div>
          <div style="font-weight:700">${g.name}</div>
          <div style="font-size:0.8rem;color:var(--text-dim)">${g.category} · ${g.edge || '—'} edge</div>
        </div>
        <div style="text-align:right">
          <div style="color:var(--green);font-weight:700">\$${Number(g.daily_revenue).toLocaleString()}</div>
          <div style="font-size:0.75rem;color:var(--text-dim)">${Number(g.players).toLocaleString()} players</div>
        </div>
      </div>
    `).join('');
  }
}

window.lightbox = function(src) {
  const overlay = document.createElement('div');
  overlay.style = 'position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px';
  overlay.innerHTML = `<img src="${src}" style="max-width:90vw;max-height:90vh;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,0.5)" onclick="event.stopPropagation()">`;
  overlay.addEventListener('click', () => overlay.remove());
  document.body.appendChild(overlay);
};

async function loadDownloads() {
  const { data } = await api('/api/downloads');
  if (!data.ok) return;
  renderTable('downloads-table', data.downloads, d => `
    <tr><td style="max-width:260px;overflow:hidden;text-overflow:ellipsis" title="${d.url}">${d.url}</td><td>${d.package_name || '—'}</td><td>${d.category}</td><td>${badge(d.status)}</td><td><button class="btn btn-sm btn-ghost" onclick="retryDownload(${d.id})"><svg class="icon" aria-hidden="true"><use href="#icon-refresh-cw"></use></svg></button></td></tr>`);
}

window.retryDownload = async function(id) {
  const { data } = await api(`/api/downloads/${id}/retry`, { method: 'POST' });
  if (data.ok) loadDownloads();
  else alert(data.error || 'Retry failed');
};

async function loadAnalytics() {
  const { data } = await api('/api/analytics');
  if (!data.ok) return;
  document.getElementById('analytics-kpis').innerHTML = `
    <div class="kpi"><div class="kpi-icon">${icon('trending-up','icon-lg')}</div><div class="kpi-label">Gross Margin</div><div class="kpi-value">${data.margin}%</div><div class="kpi-delta up">${icon('check-circle')} Healthy</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('disc','icon-lg')}</div><div class="kpi-label">Music Revenue Share</div><div class="kpi-value">${data.music_share}%</div><div class="kpi-delta up">${icon('check-circle')} Top category</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('award','icon-lg')}</div><div class="kpi-label">Deals Closed</div><div class="kpi-value">${data.deals_closed}</div><div class="kpi-delta up">${icon('arrow-up')} This quarter</div></div>
    <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-credit-card"></use></svg></div><div class="kpi-label">Cash Balance</div><div class="kpi-value">${format$(data.cash_balance)}</div><div class="kpi-delta up">${icon('arrow-up')} Daily visibility</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('clock','icon-lg')}</div><div class="kpi-label">Avg Sales Cycle</div><div class="kpi-value">${data.avg_cycle}d</div><div class="kpi-delta down">${icon('arrow-down')} From 31d</div></div>`;
  requestAnimationFrame(() => {
    drawBarChart(document.getElementById('cat-chart'), data.categories.map(c => c.label), data.categories.map(c => c.value), [cssColor('--gold'), cssColor('--purple'), cssColor('--blue'), cssColor('--green')]);
    drawBarChart(document.getElementById('team-chart'), data.team.map(t => t.label), data.team.map(t => t.value), [cssColor('--gold')]);
  });
}

async function loadAccounting(q = '') {
  const [{ data: tb }, { data: je }, { data: pl }, { data: bs }] = await Promise.all([
    api('/api/trial_balance'), api('/api/journal_entries'), api('/api/pl'), api('/api/balance_sheet')
  ]);
  if (!tb.ok) return;
  const rows = tb.accounts.filter(a => !q || Object.values(a).some(v => String(v).toLowerCase().includes(q.toLowerCase())));
  document.getElementById('acct-kpis').innerHTML = `
    <div class="kpi"><div class="kpi-icon">${icon('book-open','icon-lg')}</div><div class="kpi-label">Total Accounts</div><div class="kpi-value">${tb.accounts.length}</div></div>
    <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-bar-chart"></use></svg></div><div class="kpi-label">Total Debits</div><div class="kpi-value">${format$(tb.accounts.reduce((s,a)=>s+a.debits,0))}</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('trending-down','icon-lg')}</div><div class="kpi-label">Total Credits</div><div class="kpi-value">${format$(tb.accounts.reduce((s,a)=>s+a.credits,0))}</div></div>`;
  renderTable('acct-table', rows, a => `
    <tr data-id="${a.id}" data-type="account">
      <td>${a.code}</td><td>${a.name}</td><td>${a.type}</td><td>${format$(a.balance)}</td>
      <td><button class="btn btn-ghost btn-sm" data-action="edit" data-id="${a.id}" data-type="account">Edit</button> <button class="btn btn-danger btn-sm" data-action="delete" data-id="${a.id}" data-type="account">${icon('trash')}</button></td>
    </tr>`);
  renderTable('je-table', je, j => `
    <tr data-id="${j.id}" data-type="journal_entry">
      <td>${fmtDate(j.date)}</td><td>${j.description}</td><td>${j.debit_name}</td><td>${j.credit_name}</td><td>${format$(j.amount)}</td>
      <td><button class="btn btn-ghost btn-sm" data-action="edit" data-id="${j.id}" data-type="journal_entry">Edit</button> <button class="btn btn-danger btn-sm" data-action="delete" data-id="${j.id}" data-type="journal_entry">${icon('trash')}</button></td>
    </tr>`);
  document.getElementById('fs-kpis').innerHTML = `
    <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-dollar-sign"></use></svg></div><div class="kpi-label">Revenue</div><div class="kpi-value">${format$(pl.revenue)}</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('trending-down','icon-lg')}</div><div class="kpi-label">Expenses</div><div class="kpi-value">${format$(pl.expenses)}</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('award','icon-lg')}</div><div class="kpi-label">Net Income</div><div class="kpi-value">${format$(pl.net_income)}</div></div>`;
  document.getElementById('bs-kpis').innerHTML = `
    <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-bar-chart"></use></svg></div><div class="kpi-label">Assets</div><div class="kpi-value">${format$(bs.totals.assets)}</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('file-text','icon-lg')}</div><div class="kpi-label">Liabilities</div><div class="kpi-value">${format$(bs.totals.liabilities)}</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('users','icon-lg')}</div><div class="kpi-label">Equity</div><div class="kpi-value">${format$(bs.totals.equity)}</div></div>`;
}

async function loadProjects(q = '') {
  const { data: projects } = await api('/api/projects');
  const { data: tasks } = await api('/api/tasks');
  const container = document.getElementById('projects-list');
  const filtered = projects.filter(p => !q || Object.values(p).some(v => String(v).toLowerCase().includes(q.toLowerCase())));
  if (!filtered.length) { container.innerHTML = '<div class="loading">No projects found.</div>'; return; }
  container.innerHTML = await Promise.all(filtered.map(async p => {
    const pt = tasks.filter(t => t.project_id == p.id);
    const done = pt.filter(t => t.status === 'Done').length;
    const pct = pt.length ? Math.round(done / pt.length * 100) : 0;
    return `
    <div class="card">
      <div class="card-header">
        <div><h3>${p.name}</h3><p style="color:var(--text-muted);margin:0;font-size:0.85rem">Manager: ${p.manager || '—'} | Budget: ${format$(p.budget)} | Status: ${badge(p.status)}</p></div>
        <div><button class="btn btn-ghost btn-sm" data-action="add-task" data-id="${p.id}"><svg class="icon" aria-hidden="true"><use href="#icon-plus"></use></svg> Task</button> <button class="btn btn-ghost btn-sm" data-action="edit" data-id="${p.id}" data-type="project">Edit</button> <button class="btn btn-danger btn-sm" data-action="delete" data-id="${p.id}" data-type="project">${icon('trash')}</button></div>
      </div>
      <div style="margin-bottom:14px"><div style="background:var(--surface);height:8px;border-radius:999px;overflow:hidden"><div style="width:${pct}%;height:100%;background:linear-gradient(90deg,var(--gold),var(--gold-bright))"></div></div><div style="font-size:0.8rem;color:var(--text-muted);margin-top:6px">${done}/${pt.length} tasks complete (${pct}%)</div></div>
      <div class="table-wrap"><table><thead><tr><th>Task</th><th>Assigned</th><th>Due</th><th>Status</th><th></th></tr></thead><tbody>${pt.map(t => `
        <tr data-id="${t.id}" data-type="task">
          <td>${t.name}</td><td>${t.assigned_to || '—'}</td><td>${fmtDate(t.due_date)}</td><td>${badge(t.status)}</td>
          <td><button class="btn btn-ghost btn-sm" data-action="edit" data-id="${t.id}" data-type="task">Edit</button> <button class="btn btn-danger btn-sm" data-action="delete" data-id="${t.id}" data-type="task">${icon('trash')}</button></td>
        </tr>`).join('')}</tbody></table></div>
    </div>`;
  })).then(arr => arr.join(''));
}

async function switchPage(page) {
  currentPage = page;
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  document.querySelectorAll('#nav button').forEach(b => b.classList.toggle('active', b.dataset.page === page));
  const titleMap = { home: 'Home Base', ai: 'AI Command', accounting: 'Accounting', banking: 'Banking', trading: 'Crypto Ops', royalties: 'Royalties', vault: 'Document Vault', audit: 'Audit Log', casino: 'Casino Ops', downloads: 'Logistics', settings: 'MONOPOLY Lock' };
  document.getElementById('page-title').textContent = titleMap[page] || page.charAt(0).toUpperCase() + page.slice(1);
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('global-search').value = '';
  if (page === 'home') await loadHome();
  if (page === 'dashboard') await loadDashboard();
  if (page === 'sales') await loadSales();
  if (page === 'orders') await loadOrders();
  if (page === 'employees') await loadEmployees();
  if (page === 'finance') await loadFinance();
  if (page === 'inventory') await loadInventory();
  if (page === 'entities') await loadEntitiesPage();
  if (page === 'royalties') await loadRoyalties();
  if (page === 'accounting') await loadAccounting();
  if (page === 'projects') await loadProjects();
  if (page === 'analytics') await loadAnalytics();
  if (page === 'banking') await loadBanking();
  if (page === 'trading') await loadTrading();
  if (page === 'vault') await loadVault();
  if (page === 'audit') await loadAudit();
  if (page === 'casino') await loadCasino();
  if (page === 'downloads') await loadDownloads();
  if (page === 'ai') await loadAI();
  if (page === 'settings') await loadMonopolySettings();
}

let ollamaConfig = { ollama_url: 'http://127.0.0.1:11434', browser_url: 'http://127.0.0.1:11435' };
let ollamaModels = [];

async function loadAI() {
  const { data } = await api('/api/ollama/config');
  if (data.ok) ollamaConfig = data;
  await refreshOllamaModels();
}

async function refreshOllamaModels() {
  const sel = document.getElementById('ai-model');
  sel.innerHTML = '<option value="">ERP brain (local)</option>';
  const { data } = await api('/api/ollama/models');
  if (data && data.models) {
    ollamaModels = data.models;
    data.models.forEach(m => {
      const opt = document.createElement('option');
      opt.value = m.model || m.name;
      opt.textContent = m.model || m.name;
      sel.appendChild(opt);
    });
    // Default to the GOAT Force power model if available
    const preferred = ['llama3.1:70b', 'llama3.1:8b', 'qwen2.5:7b', 'llama3.2:3b'];
    const sel = document.getElementById('ai-model');
    for (const p of preferred) {
      if (Array.from(sel.options).some(o => o.value === p)) { sel.value = p; break; }
    }
  }
  // Also try browser-direct fallback
  try {
    const res = await fetch(ollamaConfig.browser_url + '/api/tags', { credentials: 'omit', mode: 'cors' });
    if (res.ok) {
      const d2 = await res.json();
      (d2.models || []).forEach(m => {
        const name = m.model || m.name;
        if (!Array.from(sel.options).some(o => o.value === name)) {
          const opt = document.createElement('option');
          opt.value = name;
          opt.textContent = name + ' (local Ollama)';
          sel.appendChild(opt);
        }
      });
    }
  } catch (e) { /* ignore CORS/network errors */ }
}

async function loadMonopolySettings() {
  const { data } = await api('/api/monopoly/settings');
  const statusEl = document.getElementById('monopoly-lock-status');
  const lightEl = document.getElementById('monopoly-lock-light');
  if (!data || !data.ok) {
    statusEl.textContent = 'Error';
    lightEl.className = 'status-light red';
    return;
  }
  statusEl.textContent = data.lockConfigured ? 'Locked' : 'Unconfigured';
  lightEl.className = 'status-light ' + (data.lockConfigured ? 'green' : 'amber');
  document.querySelectorAll('#monopoly-toggles input[data-cap]').forEach(cb => {
    cb.checked = !!data.settings[cb.dataset.cap];
  });
}

async function saveMonopolySettings() {
  const password = document.getElementById('monopoly-password').value;
  const settings = {};
  document.querySelectorAll('#monopoly-toggles input[data-cap]').forEach(cb => {
    settings[cb.dataset.cap] = cb.checked;
  });
  const msgEl = document.getElementById('monopoly-toggles-msg');
  msgEl.textContent = 'Saving...';
  const { data } = await api('/api/monopoly/settings', { method: 'POST', body: { password, settings } });
  if (data && data.ok) {
    msgEl.textContent = 'Capabilities saved.';
    msgEl.style.color = 'var(--green)';
    await loadMonopolySettings();
  } else {
    msgEl.textContent = data.error || 'Save failed';
    msgEl.style.color = 'var(--red)';
  }
}

async function setMonopolyPassword() {
  const input = document.getElementById('monopoly-password');
  const newPassword = input.value;
  const msgEl = document.getElementById('monopoly-password-msg');
  if (!newPassword || newPassword.length < 4) {
    msgEl.textContent = 'Password must be at least 4 characters'; msgEl.style.color = 'var(--red)'; return;
  }
  msgEl.textContent = 'Setting lock...';
  const { data } = await api('/api/monopoly/settings/password', { method: 'POST', body: { new_password: newPassword } });
  if (data && data.ok) {
    msgEl.textContent = 'Lock password set.'; msgEl.style.color = 'var(--green)'; input.value = '';
    await loadMonopolySettings();
  } else {
    msgEl.textContent = data.error || 'Set failed'; msgEl.style.color = 'var(--red)';
  }
}

