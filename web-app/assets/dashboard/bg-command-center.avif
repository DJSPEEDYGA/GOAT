// AI Assistant
document.getElementById('ai-form').addEventListener('submit', async e => {
  e.preventDefault();
  const input = document.getElementById('ai-input');
  const q = input.value.trim();
  if (!q) return;
  const chat = document.getElementById('ai-chat');
  const model = document.getElementById('ai-model').value;
  const mode = document.getElementById('ai-mode').value;
  chat.insertAdjacentHTML('beforeend', `<div class="ai-msg user">${q}</div>`);
  input.value = '';
  if (mode === 'business' && !model) {
    const { data } = await api('/api/ask', { method: 'POST', body: { q } });
    let html = `<div class="ai-msg bot">${data.answer}`;
    if (data.data && data.data.length) {
      html += `<table><thead><tr>${Object.keys(data.data[0]).map(k => `<th>${k}</th>`).join('')}</tr></thead><tbody>${data.data.map(r => `<tr>${Object.values(r).map(v => `<td>${v}</td>`).join('')}</tr>`).join('')}</tbody></table>`;
    }
    html += '</div>';
    chat.insertAdjacentHTML('beforeend', html);
  } else if (mode === 'monopoly') {
    const modelName = model || 'llama3.1:70b';
    chat.insertAdjacentHTML('beforeend', `<div class="ai-msg bot">MONOPOLY is thinking, Boss...</div>`);
    const thinking = chat.lastElementChild;
    const { data } = await api('/api/monopoly', { method: 'POST', body: { message: q, model: modelName } });
    thinking.remove();
    if (!data.ok) {
      chat.insertAdjacentHTML('beforeend', `<div class="ai-msg bot">Could not reach MONOPOLY. ${data.error || ''}</div>`);
    } else {
      const source = ` (${data.agent} · ${data.model})`;
      chat.insertAdjacentHTML('beforeend', `<div class="ai-msg bot">${data.reply}<small style="display:block;color:var(--text-muted);margin-top:6px">${source}</small></div>`);
    }
  } else {
    const modelName = model || 'llama3.1:70b';
    const messages = [{ role: 'user', content: q }];
    // Try browser-direct CORS to local Ollama first, then fall back to server proxy
    let reply = '';
    let source = '';
    try {
      const direct = await fetch(ollamaConfig.browser_url + '/api/chat', {
        method: 'POST', mode: 'cors', credentials: 'omit',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ model: modelName, messages, stream: false })
      });
      if (direct.ok) {
        const d = await direct.json();
        reply = d.message?.content || '';
        source = ' (local Ollama ' + ollamaConfig.browser_url + ')';
      }
    } catch (e) {}
    if (!reply) {
      const { data } = await api('/api/ollama/chat', { method: 'POST', body: { model: modelName, messages } });
      if (!data.ok) {
        chat.insertAdjacentHTML('beforeend', `<div class="ai-msg bot">Could not reach Ollama. ${data.error || ''}<br><small>Modes: (1) set OLLAMA_ORIGINS on your Mac Ollama to include http://147.93.72.6:8000, (2) point ERP server OLLAMA_URL to your Mac's IP, (3) run ERP locally on this Mac, or (4) install Ollama on the server.</small></div>`);
        chat.scrollTop = chat.scrollHeight;
        return;
      }
      reply = data.response;
      source = ' (server Ollama)';
    }
    chat.insertAdjacentHTML('beforeend', `<div class="ai-msg bot">${reply}<small style="display:block;color:var(--text-muted);margin-top:6px">${source}</small></div>`);
  }
  chat.scrollTop = chat.scrollHeight;
});

document.getElementById('ai-refresh-models').addEventListener('click', async () => { await refreshOllamaModels(); });

document.getElementById('monopoly-save-toggles').addEventListener('click', saveMonopolySettings);
