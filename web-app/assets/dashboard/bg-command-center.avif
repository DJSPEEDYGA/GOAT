async function askHome(q) {
  const input = document.getElementById('home-ai-input');
  const answerBox = document.getElementById('home-ai-answer');
  if (!q) q = input.value.trim();
  if (!q) return;
  input.value = q;
  const { data } = await api('/api/ask', { method: 'POST', body: { q } });
  let html = `<div class="ai-msg bot">${data.answer}`;
  if (data.data && data.data.length) {
    html += `<table><thead><tr>${Object.keys(data.data[0]).map(k => `<th>${k}</th>`).join('')}</tr></thead><tbody>${data.data.map(r => `<tr>${Object.values(r).map(v => `<td>${v}</td>`).join('')}</tr>`).join('')}</tbody></table>`;
  }
  html += '</div>';
  answerBox.innerHTML = html;
  answerBox.style.display = 'block';
}

document.getElementById('home-ai-form').addEventListener('submit', async e => { e.preventDefault(); await askHome(); });
document.querySelectorAll('.ai-chip').forEach(chip => chip.addEventListener('click', () => askHome(chip.dataset.q)));

