async function loadEntitiesPage(q = '') {
  const { data } = await api('/api/entities');
  const rows = q ? data.filter(e => Object.values(e).some(v => String(v).toLowerCase().includes(q.toLowerCase()))) : data;
  renderTable('ent-table', rows, e => `
    <tr data-id="${e.id}" data-type="entity">
      <td>${e.name}</td><td>${e.country}</td><td>${e.currency}</td><td>${e.active ? 'Yes' : 'No'}</td>
      <td><button class="btn btn-ghost btn-sm" data-action="edit" data-id="${e.id}" data-type="entity">Edit</button> <button class="btn btn-danger btn-sm" data-action="delete" data-id="${e.id}" data-type="entity">${icon('trash')}</button></td>
    </tr>`);
}
let currentBankProvider = 'plaid';

function showBankProvider(p) {
  currentBankProvider = p;
  document.querySelectorAll('.provider-tab').forEach(b => b.classList.toggle('active', b.dataset.provider === p));
  document.querySelectorAll('.provider-panel').forEach(div => div.classList.toggle('active', div.id === 'panel-' + p));
}

function showRoyaltyPanel(p) {
  document.querySelectorAll('.royalty-tab').forEach(b => b.classList.toggle('active', b.dataset.royalty === p));
  document.querySelectorAll('.royalty-panel').forEach(div => div.classList.toggle('active', div.dataset.royaltyPanel === p));
}

async function loadBanking() {
  const statusEl = document.getElementById('banking-status');
  const plaidBtn = document.getElementById('plaid-link-btn');
  const tlBtn = document.getElementById('truelayer-link-btn');

  const [plaidStatus, tlStatus] = await Promise.all([
    api('/api/plaid/status'), api('/api/truelayer/status')
  ]);

  if (!plaidStatus.data.configured && !tlStatus.data.configured) {
    statusEl.style.display = 'block';
    statusEl.textContent = 'Open Banking not configured. Add PLAID_CLIENT_ID / PLAID_SECRET (US/Canada) or TRUELAYER_CLIENT_ID / TRUELAYER_CLIENT_SECRET / TRUELAYER_REDIRECT_URI (UK/EU).';
    plaidBtn.disabled = true;
    tlBtn.disabled = true;
  } else {
    statusEl.style.display = 'none';
    plaidBtn.disabled = !plaidStatus.data.configured;
    tlBtn.disabled = !tlStatus.data.configured;
  }

  // Plaid
  if (plaidStatus.data.configured) {
    const [{ data: accountsData }, { data: txData }] = await Promise.all([
      api('/api/plaid/accounts'), api('/api/plaid/transactions?limit=50')
    ]);
    if (accountsData.ok && accountsData.accounts.length) {
      document.getElementById('plaid-accounts-card').style.display = 'block';
      renderTable('plaid-accounts-table', accountsData.accounts, a => `
        <tr><td>${a.institution_name || '—'}</td><td>${a.name}</td><td>${a.subtype || a.type}</td><td>${format$(a.balance_available)}</td><td>${format$(a.balance_current)}</td></tr>`);
    }
    if (txData.ok && txData.transactions.length) {
      document.getElementById('plaid-transactions-card').style.display = 'block';
      renderTable('plaid-transactions-table', txData.transactions, t => `
        <tr><td>${fmtDate(t.date)}</td><td>${t.name}</td><td>${format$(t.amount)}</td><td>${t.category || '—'}</td></tr>`);
    }
  }

  // TrueLayer
  if (tlStatus.data.configured) {
    const [{ data: tlAccounts }, { data: tlTx }] = await Promise.all([
      api('/api/truelayer/accounts'), api('/api/truelayer/transactions?limit=50')
    ]);
    if (tlAccounts.ok && tlAccounts.accounts.length) {
      document.getElementById('truelayer-accounts-card').style.display = 'block';
      renderTable('truelayer-accounts-table', tlAccounts.accounts, a => `
        <tr><td>${a.provider_name || '—'}</td><td>${a.display_name || '—'}</td><td>${a.account_type || '—'}</td><td>${a.currency || '—'}</td></tr>`);
    }
    if (tlTx.ok && tlTx.transactions.length) {
      document.getElementById('truelayer-transactions-card').style.display = 'block';
      renderTable('truelayer-transactions-table', tlTx.transactions, t => `
        <tr><td>${fmtDate(t.timestamp)}</td><td>${t.description || t.merchant_name || '—'}</td><td>${format$(t.amount_cents)}</td><td>${t.transaction_category || '—'}</td></tr>`);
    }
  }

  showBankProvider(currentBankProvider);
}

async function loadTrading() {
  const statusEl = document.getElementById('freqtrade-status');
  const kpis = document.getElementById('freqtrade-kpis');
  const { data } = await api('/api/freqtrade/status');
  const reachable = data && data.ok && data.reachable;

  if (!reachable) {
    statusEl.style.display = 'block';
    statusEl.textContent = 'Freqtrade not reachable. Run /opt/goat-erp/setup-freqtrade.sh on the server or set FREQTRADE_URL.';
    kpis.style.display = 'none';
    document.getElementById('freqtrade-trades-card').style.display = 'none';
    document.getElementById('freqtrade-start').disabled = true;
    document.getElementById('freqtrade-stop').disabled = true;
    return;
  }

  statusEl.style.display = 'none';
  kpis.style.display = 'grid';

  const [profit, balance, trades, config] = await Promise.all([
    api('/api/freqtrade/profit'),
    api('/api/freqtrade/balance'),
    api('/api/freqtrade/open_trades'),
    api('/api/freqtrade/show_config')
  ]);

  if (config.ok) {
    document.getElementById('ft-state').textContent = config.data && config.data.state ? config.data.state : 'running';
  }

  if (profit.ok) {
    const p = profit.data;
    document.getElementById('ft-profit').textContent = format$(Math.round((p.profit_all_coin || 0) * 100));
    document.getElementById('ft-win').textContent = (p.winning_trades || 0) + '/' + (p.trade_count || 0);
  }

  if (balance.ok && balance.data.currencies) {
    const total = balance.data.currencies.reduce((s, c) => s + (c.balance || 0), 0);
    document.getElementById('ft-balance').textContent = '$' + total.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
  }

  document.getElementById('freqtrade-start').disabled = !(config.ok && config.data.state !== 'running');
  document.getElementById('freqtrade-stop').disabled = !(config.ok && config.data.state === 'running');

  if (trades.ok && Array.isArray(trades.data)) {
    document.getElementById('freqtrade-trades-card').style.display = 'block';
    renderTable('freqtrade-trades-table', trades.data, t => `
      <tr><td>${t.pair}</td><td>${t.is_short ? 'Short' : 'Long'}</td><td>${t.open_rate ? t.open_rate.toFixed(4) : '—'}</td><td>${t.current_rate ? t.current_rate.toFixed(4) : '—'}</td><td>${t.profit_pct !== undefined ? t.profit_pct.toFixed(2)+'%' : '—'}</td></tr>`);
  }
}

async function loadRoyalties() {
  const [{ data: summary }, { data: songs }, { data: statements }] = await Promise.all([
    api('/api/royalty_summary'),
    api('/api/songs'),
    api('/api/royalty_statements?limit=50')
  ]);
  if (!summary.ok) return;
  document.getElementById('royalty-kpis').innerHTML = `
    <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-dollar-sign"></use></svg></div><div class="kpi-label">Total Royalties</div><div class="kpi-value">${format$(Math.round(summary.total_usd))}</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('disc','icon-lg')}</div><div class="kpi-label">Catalog Tracks</div><div class="kpi-value">${songs.songs.length}</div></div>
    <div class="kpi"><div class="kpi-icon"><svg class="icon icon-lg" aria-hidden="true"><use href="#icon-bar-chart"></use></svg></div><div class="kpi-label">Top Song</div><div class="kpi-value">${summary.top_track ? summary.top_track.label : '—'}</div></div>
    <div class="kpi"><div class="kpi-icon">${icon('globe','icon-lg')}</div><div class="kpi-label">DSPs</div><div class="kpi-value">10</div></div>`;
  requestAnimationFrame(() => {
    drawBarChart(document.getElementById('dsp-chart'), summary.by_dsp.map(x => x.label), summary.by_dsp.map(x => x.value), [cssColor('--gold'), cssColor('--purple'), cssColor('--blue'), cssColor('--green'), cssColor('--red')]);
    drawBarChart(document.getElementById('song-chart'), summary.by_song.map(x => x.label), summary.by_song.map(x => x.value), [cssColor('--gold')]);
  });
  renderTable('songs-table', songs.songs, s => `
    <tr><td>${s.isrc}</td><td>${s.title}</td><td>${s.artist}</td><td>${s.album || '—'}</td><td>${badge(s.status)}</td></tr>`);
  renderTable('statements-table', statements.statements, st => `
    <tr><td>${st.period}</td><td>${st.song_title}</td><td>${st.dsp_name}</td><td>${st.streams.toLocaleString()}</td><td>${format$(Math.round(st.usd_revenue))}</td></tr>`);
}

