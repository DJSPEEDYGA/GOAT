<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>GOAT FORCE — Mission Command</title>
  <meta name="description" content="GOAT Force tactical command interface for mission-critical operations." />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#f0c040" />
  <link rel="apple-touch-icon" href="/icon-192.png" />
  <link rel="stylesheet" href="/assets/hud-enhancements.css" />
  <style>
    :root {
      --bg: #030205;
      --bg-elevated: #0a0a0a;
      --surface: rgba(240,230,210,0.045);
      --surface-hover: rgba(240,230,210,0.09);
      --border: rgba(240,192,64,0.22);
      --gold: #f0c040;
      --gold-bright: #ffd700;
      --red: #c1121f;
      --blue: #58a6ff;
      --navy: #1d3557;
      --green: #a3c644;
      --green-dim: rgba(163,198,68,0.12);
      --orange: #ff9f1c;
      --purple: #bf5af2;
      --text: #f0e6d2;
      --text-muted: #8a8a78;
      --radius: 6px;
      --shadow: 0 0 0 1px rgba(240,192,64,0.07), 0 18px 50px rgba(0,0,0,0.55);
      --transition: 0.18s ease;
      --font-heading: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      --font-mono: "SF Mono", "Menlo", "Monaco", "Consolas", "Liberation Mono", monospace;
    }
    * { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; }
    body {
      font-family: var(--font-heading);
      background:
        linear-gradient(135deg, rgba(3,2,5,0.96) 0%, rgba(29,53,87,0.9) 100%),
        url('/assets/goat-superman.jpg') center 20% / cover no-repeat fixed,
        var(--bg);
      background-attachment: fixed;
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      overflow: hidden;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(240,192,64,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(240,192,64,0.05) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent 0px,
        transparent 2px,
        rgba(0,0,0,0.18) 2px,
        rgba(0,0,0,0.18) 4px
      );
      pointer-events: none;
      z-index: 1;
      opacity: 0.35;
    }
    .hud-corner {
      position: fixed; width: 22px; height: 22px;
      border: 2px solid var(--gold); z-index: 10; pointer-events: none;
      opacity: 0.8;
    }
    .hud-corner.tl { top: 10px; left: 10px; border-right: none; border-bottom: none; }
    .hud-corner.tr { top: 10px; right: 10px; border-left: none; border-bottom: none; }
    .hud-corner.bl { bottom: 10px; left: 10px; border-right: none; border-top: none; }
    .hud-corner.br { bottom: 10px; right: 10px; border-left: none; border-top: none; }
    .login-view {
      min-height: 100vh;
      display: grid;
      place-items: center;
      background:
        linear-gradient(135deg, rgba(3,2,5,0.94) 0%, rgba(29,53,87,0.92) 100%),
        url('/assets/goat-superman.jpg') center 20% / cover no-repeat fixed;
    }
    .login-card {
      width: min(420px, calc(100% - 40px));
      background: var(--surface);
      border: 1px solid var(--border);
      border-top: 3px solid var(--green);
      border-radius: var(--radius);
      padding: 38px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
      position: relative;
    }
    .login-card::before {
      content: 'TOP SECRET // GOAT FORCE COMMAND';
      position: absolute;
      top: -10px;
      right: 16px;
      background: var(--bg-elevated);
      color: var(--red);
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      padding: 2px 8px;
      border: 1px solid var(--red);
      border-radius: 3px;
      text-transform: uppercase;
    }
    .login-card h1 { margin: 0 0 8px; font-size: 1.5rem; text-transform: uppercase; letter-spacing: 0.06em; }
    .login-card p { color: var(--text-muted); margin: 0 0 26px; font-size: 0.9rem; }
    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 8px; font-weight: 500; }
    .form-group input, .form-group select {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: rgba(0,0,0,0.25);
      color: var(--text);
      font-size: 0.95rem;
      outline: none;
      font-family: inherit;
    }
    .form-group input:focus { border-color: var(--green); box-shadow: 0 0 0 3px rgba(163,198,68,0.08); }
    .btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      padding: 11px 20px; border-radius: 6px; border: none;
      font-weight: 700; font-size: 0.86rem; cursor: pointer;
      text-transform: uppercase; letter-spacing: 0.05em;
      transition: transform var(--transition), box-shadow var(--transition), background var(--transition);
      font-family: inherit;
    }
    .btn-primary { background: rgba(163,198,68,0.12); color: var(--green); border: 1px solid var(--green); }
    .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 0 16px rgba(163,198,68,0.22); background: rgba(163,198,68,0.18); }
    .btn-ghost { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
    .btn-ghost:hover { background: var(--surface-hover); color: var(--text); border-color: var(--green); }
    .btn-danger { background: rgba(255,59,48,0.10); color: var(--red); border: 1px solid rgba(255,59,48,0.35); }
    .btn-success { background: rgba(163,198,68,0.12); color: var(--green); border: 1px solid var(--green); }
    .icon-fill { fill: currentColor !important; stroke: none !important; }
    .btn-sm { padding: 8px 14px; font-size: 0.82rem; }
    .btn .icon { width: 1.05em; height: 1.05em; }
    .error-msg { color: #ff6b6b; font-size: 0.8rem; margin-top: 8px; display: none; }
    .error-msg.show { display: block; }
    .loading { color: var(--text-muted); font-size: 0.9rem; padding: 20px; }
    .icon { width: 1.1em; height: 1.1em; vertical-align: middle; color: currentColor; fill: none; stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }
    .icon-lg { width: 1.6em; height: 1.6em; }
    .icon-sq { padding: 10px; background: var(--surface-hover); border-radius: 12px; color: var(--gold); }

    .app-view { display: none; height: 100vh; grid-template-columns: 260px 1fr; grid-template-rows: 100vh; position: relative; z-index: 2; }
    .app-view.active { display: grid; }
    .login-view { position: relative; z-index: 2; }
    .sidebar {
      background: var(--bg-elevated);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column; height: 100%; min-width: 0; overflow-y: auto; padding: 22px 16px;
      box-shadow: 4px 0 20px rgba(0,0,0,0.4);
    }
    .brand { display: flex; align-items: center; gap: 12px; font-weight: 800; font-size: 0.95rem; margin-bottom: 34px; padding-left: 6px; text-transform: uppercase; letter-spacing: 0.1em; }
    .logo { width: 38px; height: 38px; border-radius: 8px; background: rgba(163,198,68,0.12); display: grid; place-items: center; color: var(--green); border: 1px solid var(--green); box-shadow: 0 0 12px rgba(163,198,68,0.15); font-family: var(--font-mono); font-weight: 800; font-size: 0.75rem; letter-spacing: 0.05em; }
    .nav { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 6px; flex: 1; }
    .nav button, .nav-link {
      width: 100%; text-align: left; padding: 11px 14px; border-radius: var(--radius); border: none; background: transparent;
      color: var(--text-muted); font-size: 0.8rem; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 12px;
      transition: all var(--transition); font-family: inherit; text-decoration: none; text-transform: uppercase; letter-spacing: 0.06em;
    }
    .nav button .icon, .nav-link .icon { color: var(--text-muted); transition: color var(--transition); }
    .nav button:hover, .nav-link:hover { background: var(--surface); color: var(--text); border-left: 3px solid var(--green); }
    .nav button:hover .icon, .nav-link:hover .icon { color: var(--green); }
    .nav button.active { background: var(--surface); color: var(--green); font-weight: 700; border-left: 3px solid var(--green); }
    .nav button.active .icon { color: var(--green); }
    .sidebar-footer { padding-top: 16px; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.7rem; font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.08em; }
    .main { display: flex; flex-direction: column; height: 100%; min-width: 0; overflow: hidden; z-index: 1; }
    .topbar {
      height: 72px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between;
      padding: 0 26px; background: rgba(5,6,7,0.85); backdrop-filter: blur(12px);
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }
    .topbar h2 { margin: 0; font-size: 1.05rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--green); }
    .topbar-actions { display: flex; align-items: center; gap: 14px; }
    .entity-select {
      background: rgba(0,0,0,0.25); border: 1px solid var(--border); border-radius: var(--radius);
      color: var(--text); padding: 8px 14px; font-size: 0.85rem; outline: none; font-family: var(--font-mono);
    }
    .search { position: relative; display: flex; align-items: center; }
    .search input {
      background: rgba(0,0,0,0.25); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 9px 14px 9px 36px; color: var(--text); width: 220px; font-size: 0.88rem; outline: none; font-family: var(--font-mono);
    }
    .search-icon { position: absolute; left: 12px; color: var(--text-muted); pointer-events: none; }
    .avatar { width: 36px; height: 36px; border-radius: 6px; background: rgba(163,198,68,0.12); display: grid; place-items: center; color: var(--green); border: 1px solid var(--green); font-family: var(--font-mono); font-weight: 800; font-size: 0.7rem; }
    .content { flex: 1; min-height: 0; min-width: 0; overflow-y: auto; padding: 26px; }
    .page { display: none; animation: fadeIn 0.25s ease; }
    .page.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

    /* Mission control status board */
    .command-bar {
      display: flex; align-items: center; gap: 22px; padding: 10px 26px;
      background: rgba(0,0,0,0.35); border-bottom: 1px solid var(--border);
      font-family: var(--font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--text-muted);
    }
    .command-bar .status-item { display: inline-flex; align-items: center; gap: 7px; }
    .status-light { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px currentColor; }
    .status-light.amber { background: var(--gold); color: var(--gold); }
    .status-light.red { background: var(--red); color: var(--red); }
    .mission-clock { margin-left: auto; color: var(--green); font-family: var(--font-mono); letter-spacing: 0.08em; }

    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 18px; margin-bottom: 26px; }
    .kpi {
      background: rgba(0,0,0,0.25); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px;
      display: flex; flex-direction: column; gap: 8px; transition: transform var(--transition), box-shadow var(--transition);
      border-left: 3px solid var(--green);
      position: relative;
    }
    .kpi::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, var(--green), transparent 60%); opacity: 0.3;
    }
    .kpi:hover { transform: translateY(-2px); background: var(--surface-hover); box-shadow: 0 0 18px rgba(163,198,68,0.08); border-color: rgba(163,198,68,0.25); }
    .kpi-label { font-size: 0.68rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; }
    .kpi-value { font-size: 1.6rem; font-weight: 800; font-family: var(--font-mono); letter-spacing: -0.01em; color: var(--green); }
    .kpi-delta { font-size: 0.84rem; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; }
    .kpi-delta.up { color: var(--green); }
    .kpi-delta.down { color: var(--red); }
    .kpi-icon { width: 44px; height: 44px; border-radius: 12px; display: grid; place-items: center; background: linear-gradient(135deg, rgba(240,192,64,0.18), rgba(193,18,31,0.18)); color: var(--gold); margin-bottom: 4px; border: 1px solid rgba(240,192,64,0.25); }
    .kpi-icon .icon { width: 22px; height: 22px; }

    .card { background: rgba(0,0,0,0.22); border: 1px solid var(--border); border-top: 2px solid var(--green); border-radius: var(--radius); padding: 22px; margin-bottom: 22px; backdrop-filter: blur(8px); box-shadow: var(--shadow); position: relative; }
    .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, var(--green), transparent 70%); opacity: 0.25; }
    .card-header h3 { margin: 0; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; }
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
    .card-header p { margin: 0; color: var(--text-muted); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; }

    .chart-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 22px; margin-bottom: 22px; }
    .chart-canvas { width: 100%; height: 260px; }

    .table-wrap { overflow-x: auto; border-radius: var(--radius); border: 1px solid var(--border); background: rgba(0,0,0,0.18); }
    table { width: 100%; border-collapse: collapse; font-size: 0.86rem; font-family: var(--font-mono); }
    th, td { padding: 11px 14px; text-align: left; border-bottom: 1px solid rgba(163,198,68,0.08); }
    th { background: rgba(163,198,68,0.05); color: var(--green); font-weight: 700; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.07em; }
    tr:hover td { background: rgba(163,198,68,0.04); }
    .badge { display: inline-block; padding: 3px 8px; border-radius: 3px; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; border: 1px solid currentColor; background: transparent; font-family: var(--font-heading); }
    .badge-open { color: var(--blue); border-color: rgba(0,200,255,0.35); background: rgba(0,200,255,0.08); }
    .badge-won { color: var(--green); border-color: rgba(163,198,68,0.35); background: rgba(163,198,68,0.08); }
    .badge-lost { color: var(--red); border-color: rgba(255,59,48,0.35); background: rgba(255,59,48,0.08); }
    .badge-paid { color: var(--green); border-color: rgba(163,198,68,0.35); background: rgba(163,198,68,0.08); }
    .badge-overdue { color: var(--red); border-color: rgba(255,59,48,0.35); background: rgba(255,59,48,0.08); }
    .badge-low { color: var(--gold); border-color: rgba(255,191,0,0.35); background: rgba(255,191,0,0.08); }
    .badge-ok { color: var(--green); border-color: rgba(163,198,68,0.35); background: rgba(163,198,68,0.08); }
    .badge-pending { color: var(--blue); border-color: rgba(0,200,255,0.35); background: rgba(0,200,255,0.08); }
    .badge-picked { color: var(--gold); border-color: rgba(255,191,0,0.35); background: rgba(255,191,0,0.08); }
    .badge-shipped { color: var(--gold); border-color: rgba(255,191,0,0.35); background: rgba(255,191,0,0.08); }
    .badge-delivered { color: var(--green); border-color: rgba(163,198,68,0.35); background: rgba(163,198,68,0.08); }

    .toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; gap: 12px; flex-wrap: wrap; }
    .toolbar input, .toolbar select { background: rgba(0,0,0,0.25); border: 1px solid var(--border); border-radius: var(--radius); padding: 9px 14px; color: var(--text); min-width: 120px; font-size: 0.9rem; outline: none; font-family: var(--font-mono); }
    .toolbar input[type="file"] { border: none; background: transparent; padding: 0; color: var(--text-muted); min-width: 180px; }
    .toolbar-right { display: flex; gap: 10px; }

    .modal-overlay {
      position: fixed; inset: 0; background: rgba(3,2,5,0.82); z-index: 500;
      display: grid; place-items: center; opacity: 0; pointer-events: none; transition: opacity var(--transition);
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal { width: min(520px, calc(100% - 32px)); max-height: 90vh; overflow-y: auto; background: var(--bg-elevated); border: 1px solid var(--border); border-top: 2px solid var(--green); border-radius: var(--radius); padding: 26px; box-shadow: var(--shadow); }
    .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 22px; }
    .modal h3 { margin: 0; font-size: 1.05rem; text-transform: uppercase; letter-spacing: 0.06em; }
    .close-modal { background: none; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    @media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }

    /* AI Assistant */
    .ai-container { display: flex; flex-direction: column; height: 70vh; gap: 14px; }
    .ai-chat { flex: 1; background: rgba(0,0,0,0.28); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 14px; }
    .ai-msg { max-width: 80%; min-width: 0; padding: 12px 16px; border-radius: 6px; font-size: 0.9rem; line-height: 1.45; word-break: break-word; overflow-wrap: break-word; }
    .ai-msg.user { align-self: flex-end; background: rgba(163,198,68,0.18); color: var(--green); border: 1px solid var(--green); }
    .ai-msg.bot { align-self: flex-start; background: rgba(0,0,0,0.35); border: 1px solid var(--border); }
    .ai-msg.bot table { margin-top: 10px; font-size: 0.82rem; width: 100%; table-layout: fixed; }
    .ai-msg.bot table th, .ai-msg.bot table td { word-break: break-word; overflow-wrap: break-word; }
    .ai-input { display: flex; gap: 10px; }
    .ai-input input { flex: 1; padding: 12px 16px; border-radius: var(--radius); border: 1px solid var(--border); background: rgba(0,0,0,0.25); color: var(--text); outline: none; font-family: var(--font-mono); }
    .ai-input input:focus { border-color: var(--green); }

    /* Provider tabs (Open Banking) */
    .provider-tabs, .royalty-tabs { display: flex; gap: 8px; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
    .provider-tab, .royalty-tab { background: transparent; border: 1px solid var(--border); color: var(--text-muted); padding: 8px 14px; border-radius: var(--radius); cursor: pointer; font-size: 0.78rem; transition: all var(--transition); text-transform: uppercase; letter-spacing: 0.05em; }
    .provider-tab.active, .royalty-tab.active { background: rgba(163,198,68,0.12); color: var(--green); border-color: var(--green); font-weight: 700; }
    .provider-tab:hover:not(.active), .royalty-tab:hover:not(.active) { border-color: var(--green); color: var(--green); }
    .provider-panel, .royalty-panel { display: none; }
    .provider-panel.active, .royalty-panel.active { display: block; animation: fadeIn 0.25s ease; }

    /* Home / Mission Control */
    .home-header { display: flex; justify-content: space-between; align-items: flex-end; gap: 20px; margin-bottom: 24px; flex-wrap: wrap; }
    .home-greeting { color: var(--green); font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 4px; }
    .home-header h1 { margin: 0; font-size: 1.6rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .home-subtitle { color: var(--text-muted); font-size: 0.9rem; margin: 4px 0 0; }
    .home-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .section-title { font-size: 0.95rem; margin: 28px 0 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
    .app-tiles { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 18px; }
    .app-tile {
      background: rgba(0,0,0,0.22); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px;
      cursor: pointer; transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
      display: flex; flex-direction: column; gap: 12px; position: relative; overflow: hidden;
      color: inherit; text-decoration: none;
    }
    .app-tile:hover { transform: translateY(-3px); border-color: var(--green); box-shadow: 0 0 18px rgba(163,198,68,0.08); }
    .app-tile::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--green), transparent 70%); opacity: 0.3; }
    .app-tile-icon { width: 48px; height: 48px; border-radius: 8px; display: grid; place-items: center; background: rgba(163,198,68,0.08); color: var(--green); border: 1px solid rgba(163,198,68,0.18); }
    .app-tile-icon .icon { width: 24px; height: 24px; }
    .app-tile h4 { margin: 0; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .app-tile p { margin: 0; color: var(--text-muted); font-size: 0.8rem; }
    .app-tile .tile-count { font-size: 1.3rem; font-weight: 800; font-family: var(--font-mono); color: var(--green); }
    .ai-prompt { margin-bottom: 24px; }
    .ai-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
    .ai-chip { background: rgba(0,0,0,0.25); border: 1px solid var(--border); color: var(--text-muted); padding: 6px 12px; border-radius: var(--radius); font-size: 0.75rem; cursor: pointer; transition: all var(--transition); text-transform: uppercase; letter-spacing: 0.04em; }
    .ai-chip:hover { border-color: var(--green); color: var(--green); }
    .home-bottom { display: flex; gap: 22px; margin-top: 28px; flex-wrap: wrap; }

    .menu-toggle { display: none; background: var(--surface); border: 1px solid var(--border); color: var(--text); border-radius: 10px; width: 36px; height: 36px; cursor: pointer; padding: 0; }
    @media (max-width: 900px) {
      .app-view { grid-template-columns: 1fr; }
      .sidebar { position: fixed; inset: 0 auto 0 0; width: 260px; z-index: 300; transform: translateX(-100%); transition: transform var(--transition); }
      .sidebar.open { transform: translateX(0); }
      .menu-toggle { display: block; }
      .search input { width: 150px; }
      .entity-select { display: none; }
      .kpi-grid { grid-template-columns: 1fr 1fr; }
      .chart-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .kpi-grid { grid-template-columns: 1fr; }
      .topbar { padding: 0 14px; }
      .content { padding: 16px; }
      .topbar-actions { gap: 8px; }
    }
  </style>
  <script src="https://cdn.plaid.com/link/v2/stable/link-initialize.js"></script>
<style>
  /* Mission Control theme overrides for all pages */
  .mc-mode { --panel: rgba(5,16,5,0.82); --grid: rgba(163,198,68,0.10); --grid-strong: rgba(163,198,68,0.18); --amber: #ffb000; --text-dim: #7a9c7a; }
  .hud-corner { position: fixed; width: 26px; height: 26px; border: 2px solid var(--green); z-index: 100; pointer-events: none; }
  .hud-corner.tl { top: 12px; left: 12px; border-right: none; border-bottom: none; }
  .hud-corner.tr { top: 12px; right: 12px; border-left: none; border-bottom: none; }
  .hud-corner.bl { bottom: 12px; left: 12px; border-right: none; border-top: none; }
  .hud-corner.br { bottom: 12px; right: 12px; border-left: none; border-top: none; }
  body.mc-mode::before { background-size: 60px 60px; background-image: linear-gradient(var(--grid) 1px, transparent 1px), linear-gradient(90deg, var(--grid) 1px, transparent 1px); }
  body.mc-mode::after { opacity: 0.35; background: repeating-linear-gradient(0deg, transparent 0px, transparent 2px, rgba(0,0,0,0.18) 2px, rgba(0,0,0,0.18) 4px); }
  .mc-mode .topbar { background: rgba(3,8,3,0.88); border-bottom: 1px solid var(--green-dim); }
  .mc-mode .sidebar { background: var(--panel); border-right: 1px solid var(--green-dim); }
  .mc-mode .content { background: transparent; }
  .mc-mode .card { background: var(--panel); border: 1px solid var(--green-dim); border-top: 2px solid var(--green); border-radius: 6px; position: relative; padding: 18px; backdrop-filter: blur(6px); box-shadow: none; }
  .mc-mode .card::before { content: ''; position: absolute; top: -1px; left: 18px; right: 18px; height: 2px; background: linear-gradient(90deg, transparent, var(--green), transparent); opacity: 0.6; }
  .mc-mode .card-header { margin-bottom: 14px; }
  .mc-mode .card-header h3 { font-size: 0.72rem; color: var(--green); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 800; }
  .mc-mode .card-header p { color: var(--text-dim); font-size: 0.65rem; letter-spacing: 0.04em; text-transform: uppercase; }
  .mc-mode .kpi { background: rgba(0,0,0,0.25); border: 1px solid var(--green-dim); border-left: 3px solid var(--green); border-radius: 4px; padding: 14px; position: relative; gap: 6px; transition: none; }
  .mc-mode .kpi::before { background: none; }
  .mc-mode .kpi:hover { transform: none; background: rgba(0,0,0,0.25); box-shadow: none; border-color: var(--green-dim); }
  .mc-mode .kpi-icon { width: 34px; height: 34px; border-radius: 8px; margin-bottom: 0; }
  .mc-mode .kpi-label { font-size: 0.62rem; color: var(--text-dim); }
  .mc-mode .kpi-value { font-size: 1.55rem; color: var(--green); letter-spacing: 0; }
  .mc-mode .kpi.amber { border-left-color: var(--amber); }
  .mc-mode .kpi.amber .kpi-value { color: var(--amber); }
  .mc-mode .kpi.red { border-left-color: var(--red); }
  .mc-mode .kpi.red .kpi-value { color: var(--red); }
  .mc-mode .table-wrap { border: 1px solid var(--green-dim); background: rgba(0,0,0,0.18); border-radius: 6px; }
  .mc-mode .table-wrap th { color: var(--green); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .mc-mode .btn { border-radius: 4px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
  .mc-mode .btn-primary { background: rgba(163,198,68,0.12); color: var(--green); border: 1px solid var(--green); }
  .mc-mode .btn-ghost { background: transparent; color: var(--text-dim); border: 1px solid var(--green-dim); }
  .mc-mode .btn-ghost:hover { background: rgba(163,198,68,0.08); color: var(--green); border-color: var(--green); }
  .mc-mode .command-bar { background: rgba(0,0,0,0.35); border-bottom: 1px solid var(--green-dim); }
  .mc-mode .form-group input, .mc-mode .form-group select, .mc-mode .toolbar input, .mc-mode .toolbar select { border-radius: 4px; border: 1px solid var(--green-dim); background: rgba(0,0,0,0.25); color: var(--text); }
</style>
<style>
  /* Mission Control — rest-of-app theme fixes */
  .mc-mode .home-header { background: var(--panel); border: 1px solid var(--green-dim); border-left: 3px solid var(--green); border-radius: 6px; padding: 22px; display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 22px; position: relative; }
  .mc-mode .home-header::before { content: ''; position: absolute; top: -1px; left: 22px; right: 22px; height: 2px; background: linear-gradient(90deg, transparent, var(--green), transparent); opacity: 0.6; }
  .mc-mode .home-greeting { font-size: 0.65rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 6px; }
  .mc-mode #home-title { font-size: 1.6rem; margin: 0; color: var(--green); }
  .mc-mode .home-subtitle { color: var(--text-dim); font-size: 0.78rem; margin: 4px 0 0; }
  .mc-mode .home-actions { display: flex; gap: 10px; }
  .mc-mode .section-title { color: var(--green); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.12em; margin: 28px 0 14px; font-weight: 800; border-bottom: 1px solid var(--green-dim); padding-bottom: 8px; }
  .mc-mode .app-tiles { gap: 14px; }
  .mc-mode .app-tile { background: var(--panel); border: 1px solid var(--green-dim); border-radius: 6px; padding: 18px; position: relative; }
  .mc-mode .app-tile::before { content: ''; position: absolute; top: -1px; left: 18px; right: 18px; height: 2px; background: linear-gradient(90deg, transparent, var(--green), transparent); opacity: 0.6; }
  .mc-mode .app-tile:hover { transform: translateY(-2px); border-color: var(--green); box-shadow: 0 0 18px rgba(163,198,68,0.08); }
  .mc-mode .app-tile h4 { font-size: 0.78rem; color: var(--text); }
  .mc-mode .app-tile p { color: var(--text-dim); font-size: 0.72rem; }
  .mc-mode .app-tile-icon { width: 44px; height: 44px; border-radius: 8px; background: rgba(0,0,0,0.25); border: 1px solid var(--green-dim); color: var(--green); }
  .mc-mode .home-bottom { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 18px; }
  .mc-mode .ai-prompt { background: var(--panel); border: 1px solid var(--green-dim); border-top: 2px solid var(--blue); border-radius: 6px; padding: 18px; position: relative; margin-bottom: 22px; }
  .mc-mode .ai-prompt::before { content: ''; position: absolute; top: -1px; left: 18px; right: 18px; height: 2px; background: linear-gradient(90deg, transparent, var(--blue), transparent); opacity: 0.6; }
  .mc-mode .ai-chip { background: rgba(0,0,0,0.25); border: 1px solid var(--green-dim); color: var(--text-dim); border-radius: 4px; padding: 6px 12px; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .mc-mode .ai-chip:hover { border-color: var(--green); color: var(--green); background: rgba(163,198,68,0.08); }
  .mc-mode .ai-input input { border-radius: 4px; border: 1px solid var(--green-dim); background: rgba(0,0,0,0.25); color: var(--text); }
  .mc-mode .ai-input button { background: rgba(163,198,68,0.12); color: var(--green); border: 1px solid var(--green); border-radius: 4px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
  .mc-mode .ai-msg { background: rgba(0,0,0,0.25); border: 1px solid var(--green-dim); border-radius: 6px; padding: 12px; }
  .mc-mode .ai-msg.bot { border-left: 3px solid var(--green); }
  .mc-mode .btn-success { background: rgba(163,198,68,0.12); color: var(--green); border: 1px solid var(--green); }
  .mc-mode .btn-danger { background: rgba(255,42,42,0.12); color: var(--red); border: 1px solid var(--red); }
  .mc-mode .btn-sm { font-size: 0.72rem; padding: 7px 12px; }
  .mc-mode .provider-tabs, .mc-mode .royalty-tabs { display: flex; gap: 10px; margin-bottom: 0; border-bottom: 1px solid var(--green-dim); }
  .mc-mode .provider-tab, .mc-mode .royalty-tab { background: transparent; border: 1px solid transparent; border-bottom: none; color: var(--text-dim); padding: 10px 16px; border-radius: 4px 4px 0 0; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.06em; cursor: pointer; }
  .mc-mode .provider-tab.active, .mc-mode .royalty-tab.active { background: rgba(163,198,68,0.08); border-color: var(--green-dim); color: var(--green); border-top: 2px solid var(--green); }
  .mc-mode .provider-panel, .mc-mode .royalty-panel { background: var(--panel); border: 1px solid var(--green-dim); border-radius: 0 6px 6px 6px; padding: 18px; margin-bottom: 22px; }
  .mc-mode .chart-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 18px; }
  .mc-mode .chart-canvas { border: 1px solid var(--green-dim); border-radius: 6px; background: rgba(0,0,0,0.18); padding: 10px; }
  .mc-mode .hero-banner { border: 1px solid var(--green-dim); border-radius: 6px; background: linear-gradient(90deg, rgba(3,8,3,0.95), rgba(3,8,3,0.7)), radial-gradient(circle at 80% 50%, rgba(163,198,68,0.12), transparent 50%), var(--panel) !important; position: relative; overflow: hidden; }
  .mc-mode .hero-banner::before { content: '◆ MISSION READY'; position: absolute; top: 12px; right: 18px; font-family: var(--font-mono); font-size: 0.65rem; color: var(--green); letter-spacing: 0.12em; opacity: 0.7; }
  .mc-mode .form-group label { color: var(--text-dim); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .mc-mode .form-group input, .mc-mode .form-group select, .mc-mode .form-group textarea { border-radius: 4px; border: 1px solid var(--green-dim); background: rgba(0,0,0,0.25); color: var(--text); }
  .mc-mode .modal { background: var(--panel); border: 1px solid var(--green-dim); border-top: 2px solid var(--green); border-radius: 6px; box-shadow: none; }
  .mc-mode .modal-header h3 { color: var(--green); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; }
  .mc-mode .close-modal { color: var(--text-dim); }
  .mc-mode .close-modal:hover { color: var(--green); }
  .mc-mode .loading { color: var(--green); font-family: var(--font-mono); }
  .mc-mode .error-msg { color: var(--red); font-size: 0.78rem; }
  .mc-mode .login-view { background: radial-gradient(circle at 50% 30%, rgba(163,198,68,0.08), transparent 50%), var(--bg); }
  .mc-mode .login-card { background: var(--panel); border: 1px solid var(--green-dim); border-top: 2px solid var(--green); border-radius: 6px; box-shadow: none; padding: 32px; }
  .mc-mode .login-card h1 { color: var(--green); }
  .mc-mode .login-card p { color: var(--text-dim); }
  .mc-mode .page { position: relative; }
  .mc-mode .page::before { content: ''; position: absolute; top: 12px; right: 24px; width: 80px; height: 80px; border-radius: 50%; background: conic-gradient(from 0deg, transparent 0deg, rgba(163,198,68,0.22) 45deg, transparent 90deg), repeating-radial-gradient(circle at center, transparent 0, transparent 18px, rgba(163,198,68,0.08) 19px, transparent 20px), linear-gradient(90deg, rgba(163,198,68,0.05) 1px, transparent 1px), linear-gradient(0deg, rgba(163,198,68,0.05) 1px, transparent 1px); opacity: 0.15; pointer-events: none; z-index: 0; }
</style>
</head>
<body class="mc-mode">
<div class="hud-corner tl"></div>
<div class="hud-corner tr"></div>
<div class="hud-corner bl"></div>
<div class="hud-corner br"></div>

